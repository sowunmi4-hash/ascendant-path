<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Opened Record | The Ascendant Path</title>
  <link rel="stylesheet" href="style.css" />
  <link rel="stylesheet" href="/cultivation-book.css" />
  <style>
    :root {
      --panel-bg: linear-gradient(180deg, rgba(16, 22, 38, 0.88), rgba(8, 12, 22, 0.96));
      --panel-border: rgba(255, 255, 255, 0.08);
      --panel-shadow: 0 18px 42px rgba(0, 0, 0, 0.24);
      --soft-text: rgba(225, 232, 255, 0.78);
      --dim-text: rgba(196, 208, 255, 0.62);
      --bright-text: #f3f7ff;
      --gold: #fff0c7;
      --gold-soft: rgba(255, 240, 199, 0.12);
      --green: #88e487;
      --green-soft: rgba(136, 228, 135, 0.14);
      --blue: #8ea8ff;
      --blue-soft: rgba(142, 168, 255, 0.14);
      --amber: #ffbe69;
      --amber-soft: rgba(255, 190, 105, 0.14);
      --danger: #ff8c8c;
      --danger-soft: rgba(255, 140, 140, 0.14);
      --track: rgba(255, 255, 255, 0.08);
    }

    .record-page {
      width: min(1380px, calc(100% - 2rem));
      margin: 1.35rem auto 4rem;
      display: grid;
      gap: 1.15rem;
      position: relative;
      z-index: 3;
      isolation: isolate;
    }

    .is-hidden { display: none !important; }

    .record-hero {
      position: relative;
      overflow: hidden;
      min-height: 310px;
      padding: 1.7rem 1.7rem 1.55rem;
      border: 1px solid var(--panel-border);
      box-shadow: var(--shadow-lg, 0 18px 42px rgba(0, 0, 0, 0.24));
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(7, 10, 18, 0.18), rgba(7, 10, 18, 0.88)),
        radial-gradient(circle at 16% 18%, rgba(255, 240, 199, 0.10), transparent 24%),
        radial-gradient(circle at 78% 18%, rgba(142, 168, 255, 0.16), transparent 24%),
        url("https://images.unsplash.com/photo-1518562180175-34a163b1a9a6?auto=format&fit=crop&w=1800&q=80")
        center 52% / cover no-repeat;
    }

    .record-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(6,10,18,0.9) 0%, rgba(6,10,18,0.48) 45%, rgba(6,10,18,0.9) 100%);
      pointer-events: none;
    }

    .record-hero::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 132px;
      background: linear-gradient(180deg, transparent, rgba(6,10,18,0.78));
      pointer-events: none;
    }

    .record-hero > * { position: relative; z-index: 1; }

    .hero-kicker {
      display: inline-block;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #bfd0ff;
      margin-bottom: 0.2rem;
    }

    .hero-top-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .hero-title-wrap h1 {
      margin: 0;
      font-size: clamp(2.2rem, 4vw, 3.35rem);
      line-height: 1;
      color: #ffffff;
      text-shadow: 0 6px 18px rgba(0,0,0,0.34);
    }

    .hero-subtitle {
      margin: 0.55rem 0 0;
      max-width: 780px;
      color: rgba(228,235,255,0.84);
      line-height: 1.6;
      font-size: 0.96rem;
    }

    .hero-state-badge {
      align-self: flex-start;
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.78rem 1rem;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.07);
      color: #f6f8ff;
      font-size: 0.92rem;
      font-weight: 700;
      backdrop-filter: blur(10px);
    }

    .hero-state-badge::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: currentColor;
      box-shadow: 0 0 12px currentColor;
    }

    .hero-state-badge.cultivating { color: var(--green); }
    .hero-state-badge.paused { color: var(--amber); }
    .hero-state-badge.cooldown { color: var(--amber); }
    .hero-state-badge.damaged { color: var(--danger); }
    .hero-state-badge.reopened { color: var(--blue); }
    .hero-state-badge.breakthrough { color: var(--gold); }
    .hero-state-badge.complete { color: var(--green); }
    .hero-state-badge.idle { color: #d9e2ff; }

    .hero-meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-top: 1rem;
    }

    .hero-meta-pill {
      border-radius: 999px;
      padding: 0.64rem 0.92rem;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
      color: #eef3ff;
      font-size: 0.92rem;
    }

    .hero-message { margin: 0; text-align: center; }

    .vessel-gate-panel {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #c8a96a22;
      transition: border-color 0.5s ease;
    }
    .vessel-gate-panel.state-cultivating { border-color: #3a608055; }
    .vessel-gate-panel.state-open        { border-color: #c8a96a88; }
    .vessel-gate-panel.state-active      { border-color: #e8a84055; }
    .vessel-gate-panel.state-damaged     { border-color: #7a202055; }
    .vessel-gate-panel.state-complete    { border-color: #c8a96a33; }
    .vessel-gate-panel.state-sealed      { border-color: #222; }
    .vessel-side {
      background: #08090f;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1rem 1rem;
      border-right: 1px solid #ffffff0f;
      min-height: 380px;
    }
    .vessel-side-head {
      position: absolute;
      top: 12px;
      left: 14px;
    }
    .vessel-side-kicker {
      font-size: 10px;
      font-weight: 500;
      color: rgba(255,255,255,0.25);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin: 0 0 2px;
    }
    .vessel-side-title {
      font-size: 13px;
      font-weight: 500;
      color: rgba(255,255,255,0.6);
      margin: 0;
    }
    .vessel-canvas-wrap {
      position: relative;
      width: 340px;
      height: 340px;
    }
    .vessel-qi-bar-wrap {
      position: absolute;
      bottom: 12px;
      left: 14px;
      right: 14px;
    }
    .vessel-qi-bar-label {
      font-size: 10px;
      color: rgba(255,255,255,0.3);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0 0 4px;
    }
    .vessel-qi-bar-label span {
      color: #c8a96a;
      margin-left: 4px;
    }
    .vessel-qi-bar-track {
      height: 3px;
      background: rgba(255,255,255,0.06);
      border-radius: 2px;
      overflow: hidden;
    }
    .vessel-qi-bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 0.8s ease;
    }
    .gate-side {
      position: relative;
      min-height: 380px;
      display: flex;
      flex-direction: column;
    }
    .gate-side .gate-wrap {
      flex: 1;
      border-radius: 0;
      border: none;
      border-color: transparent;
    }
    .gate-side .gate-scene {
      flex: 1;
      height: auto;
      min-height: 240px;
    }
    .record-stats-bar {
      background: #0d0a00;
      border: 0.5px solid #c8a96a22;
      border-radius: 12px;
      padding: 1rem 1.25rem;
    }
    .record-stats-row {
      display: flex;
      gap: 10px;
      margin-bottom: 1rem;
    }
    .record-stat-box {
      flex: 1;
      background: #0a0800;
      border: 0.5px solid #c8a96a22;
      border-radius: 8px;
      padding: 10px 14px;
    }
    .record-stat-box span {
      display: block;
      font-size: 10px;
      font-weight: 500;
      color: #c8a96a88;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 4px;
    }
    .record-stat-box strong {
      display: block;
      font-size: 18px;
      font-weight: 500;
      color: #c8a96a;
    }
    .record-lower-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      align-items: start;
    }

    .record-panel {
      position: relative;
      background: var(--panel-bg);
      border-top: 1px solid var(--panel-border);
      border-bottom: 1px solid var(--panel-border);
      box-shadow: var(--panel-shadow);
      overflow: hidden;
    }

    .record-panel::before {
      content: "";
      position: absolute;
      left: 0;
      top: 18px;
      bottom: 18px;
      width: 2px;
      background: linear-gradient(180deg, rgba(142,168,255,0.32), rgba(255,240,199,0.18));
    }

    .record-panel-head { padding: 1rem 1rem 0; }
    .record-panel-kicker { margin: 0; padding-left: 0.25rem; font-size: 0.76rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--dim-text); }
    .record-panel-title { margin: 0.35rem 0 0; padding-left: 0.25rem; color: #fff; font-size: 1.3rem; }
    .record-panel-subtitle { margin: 0.45rem 0 0; padding-left: 0.25rem; color: var(--soft-text); line-height: 1.55; font-size: 0.94rem; }

    .path-panel { min-height: 100%; display: grid; gap: 0.95rem; padding-bottom: 1rem; }
    .path-list { display: grid; gap: 0.85rem; padding: 0 1rem 1rem; margin-top: 0.25rem; }

    .path-node {
      position: relative;
      display: grid;
      gap: 0.55rem;
      padding: 0.95rem 0.95rem 0.95rem 1rem;
      background: rgba(255,255,255,0.035);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
      overflow: hidden;
    }

    .path-node + .path-node::before {
      content: "";
      position: absolute;
      left: 24px;
      top: -15px;
      width: 2px;
      height: 15px;
      background: linear-gradient(180deg, rgba(142,168,255,0.35), rgba(255,255,255,0));
    }

    .path-node.current {
      border-color: rgba(127,214,106,0.22);
      box-shadow: 0 0 0 1px rgba(127,214,106,0.14);
      transform: translateY(-1px);
    }

    .path-node.damaged {
      border-color: rgba(255,140,140,0.2);
      background: linear-gradient(180deg, rgba(72,24,30,0.34), rgba(16,12,18,0.94));
    }

    .path-node.reopened {
      border-color: rgba(142,168,255,0.2);
      background: linear-gradient(180deg, rgba(23,32,56,0.42), rgba(9,13,22,0.94));
    }

    .path-node.comprehended {
      border-color: rgba(136,228,135,0.18);
    }

    .path-node.breakthrough_pending,
    .path-node.breakthrough_active,
    .path-node.breakthrough_ready,
    .path-node.breakthrough_cooldown {
      border-color: rgba(255,240,199,0.2);
      background: linear-gradient(180deg, rgba(54,46,22,0.24), rgba(12,10,15,0.92));
    }

    .path-node.breakthrough_cooldown {
      border-color: rgba(255,190,105,0.2);
      background: linear-gradient(180deg, rgba(54,34,16,0.24), rgba(12,10,15,0.92));
    }

    .path-node-top { display: flex; justify-content: space-between; gap: 0.75rem; align-items: flex-start; }
    .path-node-title { margin: 0; color: #fff; font-size: 1.05rem; }
    .path-node-book { margin: 0.3rem 0 0; color: var(--soft-text); line-height: 1.45; font-size: 0.88rem; }

    .path-node-state {
      white-space: nowrap;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.35rem 0.55rem;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.06);
      color: #eef3ff;
    }

    .path-node-state.cultivating { color: var(--green); background: var(--green-soft); }
    .path-node-state.complete { color: var(--gold); background: var(--gold-soft); }
    .path-node-state.open { color: var(--blue); background: var(--blue-soft); }
    .path-node-state.paused { color: var(--amber); background: var(--amber-soft); }
    .path-node-state.damaged { color: var(--danger); background: var(--danger-soft); }
    .path-node-state.comprehended { color: var(--green); background: var(--green-soft); }
    .path-node-state.breakthrough_pending,
    .path-node-state.breakthrough_active,
    .path-node-state.breakthrough_ready { color: var(--gold); background: var(--gold-soft); }
    .path-node-state.breakthrough_cooldown { color: var(--amber); background: var(--amber-soft); }
    .path-node-state.sealed { color: rgba(235,241,255,0.74); }

    .mini-track { width: 100%; height: 8px; background: var(--track); border-radius: 999px; overflow: hidden; }
    .mini-fill { height: 100%; width: 0%; border-radius: 999px; background: linear-gradient(135deg, #8ea8ff, #7fd66a); transition: width 0.25s ease; }
    .path-node.damaged .mini-fill { background: linear-gradient(135deg, #ff8c8c, #ffbe69); }
    .path-node.breakthrough_pending .mini-fill,
    .path-node.breakthrough_active .mini-fill,
    .path-node.breakthrough_ready .mini-fill { background: linear-gradient(135deg, #fff0c7, #ffbe69); }
    .path-node.breakthrough_cooldown .mini-fill { background: linear-gradient(135deg, #ffbe69, #8ea8ff); }

    .path-node-meta { display: flex; justify-content: space-between; gap: 0.75rem; font-size: 0.84rem; color: var(--soft-text); }
    .path-node-note { margin: 0; color: var(--dim-text); line-height: 1.5; font-size: 0.84rem; }

    .altar-panel { display: grid; gap: 1rem; padding: 1rem; min-height: 100%; }

    .altar-visual {
      position: relative;
      min-height: 390px;
      display: grid;
      place-items: center;
      border-radius: 24px;
      overflow: hidden;
      background:
        radial-gradient(circle at center, rgba(142,168,255,0.12), transparent 38%),
        linear-gradient(180deg, rgba(10,16,28,0.92), rgba(5,9,18,0.96));
      border: 1px solid rgba(255,255,255,0.06);
    }

    .altar-visual::before,
    .altar-visual::after {
      content: "";
      position: absolute;
      inset: 14% 18%;
      border-radius: 50%;
      border: 1px solid rgba(142,168,255,0.12);
      animation: altarSpin 28s linear infinite;
    }

    .altar-visual::after {
      inset: 22% 26%;
      animation-direction: reverse;
      animation-duration: 18s;
      border-color: rgba(255,240,199,0.12);
    }

    .altar-stage { position: relative; width: min(320px, 72%); aspect-ratio: 1; display: grid; place-items: center; }

    .altar-core {
      position: relative;
      width: 58%;
      aspect-ratio: 1;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 35% 35%, rgba(255,255,255,0.28), rgba(255,255,255,0) 26%),
        radial-gradient(circle at 50% 50%, rgba(142,168,255,0.3), rgba(65,91,170,0.2) 56%, rgba(21,30,60,0.2) 78%, rgba(0,0,0,0) 100%);
      box-shadow: 0 0 40px rgba(142,168,255,0.22), 0 0 90px rgba(142,168,255,0.08);
      animation: altarPulse 4.2s ease-in-out infinite;
      overflow: hidden;
    }

    .altar-core::before { content: ""; position: absolute; inset: 10%; border-radius: 50%; border: 1px solid rgba(255,255,255,0.12); opacity: 0.6; }
    .altar-core::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0)), radial-gradient(circle at 50% 80%, rgba(127,214,106,0.18), transparent 32%); mix-blend-mode: screen; pointer-events: none; }

    .altar-ring { position: absolute; inset: 4%; border-radius: 50%; border: 1px dashed rgba(255,255,255,0.1); animation: altarSpin 22s linear infinite; }
    .altar-ring.ring-two { inset: 0; animation-direction: reverse; animation-duration: 30s; border-color: rgba(142,168,255,0.16); }
    .altar-ring.ring-three { inset: -5%; animation-duration: 40s; border-color: rgba(255,240,199,0.12); }

    .altar-fracture {
      display: none;
      position: absolute;
      inset: 18%;
      background:
        linear-gradient(120deg, transparent 0 42%, rgba(255,120,120,0.85) 47%, transparent 52%),
        linear-gradient(65deg, transparent 0 38%, rgba(255,190,105,0.65) 43%, transparent 48%);
      filter: blur(0.4px);
      opacity: 0.8;
      animation: fracturePulse 2.2s ease-in-out infinite;
      pointer-events: none;
    }

    .altar-particles { position: absolute; inset: 0; pointer-events: none; }
    .altar-particle { position: absolute; width: 6px; height: 6px; border-radius: 50%; background: rgba(142,168,255,0.78); box-shadow: 0 0 12px rgba(142,168,255,0.72); animation: floatParticle 7s linear infinite; opacity: 0.75; }
    .altar-particle:nth-child(2) { left: 18%; top: 68%; animation-duration: 8s; animation-delay: -2s; }
    .altar-particle:nth-child(3) { left: 72%; top: 66%; animation-duration: 9s; animation-delay: -4s; }
    .altar-particle:nth-child(4) { left: 26%; top: 24%; animation-duration: 10s; animation-delay: -6s; }
    .altar-particle:nth-child(5) { left: 62%; top: 24%; animation-duration: 8.5s; animation-delay: -1s; }
    .altar-particle:nth-child(6) { left: 50%; top: 12%; animation-duration: 11s; animation-delay: -3s; }

    .altar-visual[data-state="cultivating"] .altar-core { box-shadow: 0 0 46px rgba(127,214,106,0.28), 0 0 100px rgba(127,214,106,0.1); animation-duration: 3.2s; }
    .altar-visual[data-state="paused"] .altar-core,
    .altar-visual[data-state="cooldown"] .altar-core { opacity: 0.76; filter: saturate(0.8); animation-duration: 6s; }
    .altar-visual[data-state="damaged"] .altar-core { box-shadow: 0 0 44px rgba(255,140,140,0.28), 0 0 100px rgba(255,140,140,0.08); filter: saturate(0.84); }
    .altar-visual[data-state="damaged"] .altar-fracture { display: block; }
    .altar-visual[data-state="breakthrough"] .altar-core { box-shadow: 0 0 52px rgba(255,240,199,0.28), 0 0 110px rgba(255,240,199,0.1); }
    .altar-visual[data-state="complete"] .altar-core { box-shadow: 0 0 52px rgba(127,214,106,0.28), 0 0 110px rgba(127,214,106,0.1); }

    .altar-center-text { position: absolute; inset: 0; display: grid; align-content: center; justify-items: center; gap: 0.35rem; text-align: center; z-index: 2; padding: 1rem; }
    .altar-center-kicker { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--dim-text); }
    .altar-center-value { color: #fff; font-size: 1.9rem; line-height: 1; font-weight: 700; }
    .altar-center-caption { color: var(--soft-text); font-size: 0.9rem; line-height: 1.45; max-width: 220px; }

    .altar-focus-panel { display: grid; gap: 0.95rem; }
    .altar-focus-top { display: flex; justify-content: space-between; gap: 1rem; align-items: flex-start; flex-wrap: wrap; }
    .altar-focus-title { margin: 0; color: #fff; font-size: 1.45rem; }
    .altar-focus-book { margin: 0.35rem 0 0; color: var(--soft-text); line-height: 1.55; font-size: 0.94rem; }
    .altar-focus-badge { border-radius: 999px; padding: 0.58rem 0.85rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); color: #eef3ff; font-size: 0.86rem; font-weight: 700; white-space: nowrap; }

    .altar-progress-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 0.75rem; }
    .altar-stat { padding: 0.9rem 0.95rem; border-radius: 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); }
    .altar-stat span { display: block; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim-text); }
    .altar-stat strong { display: block; margin-top: 0.28rem; color: #fff; font-size: 1rem; line-height: 1.4; }

    .action-well { display: grid; gap: 0.75rem; padding-top: 0.2rem; }
    .action-primary, .action-secondary {
      min-height: 54px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-weight: 700;
      padding: 0.95rem 1rem;
      position: relative;
      transition: 0.2s ease;
      text-align: center;
      cursor: pointer;
      border-radius: 14px;
    }

    .action-primary {
      border: none;
      background: linear-gradient(135deg, #7fd66a, #4fae48);
      color: #081506;
      box-shadow: 0 14px 30px rgba(79,174,72,0.28);
    }

    .action-primary[aria-disabled="true"], .action-secondary[aria-disabled="true"] {
      opacity: 0.62;
      pointer-events: none;
      cursor: default;
    }

    .action-secondary {
      background: rgba(255,255,255,0.04);
      border-top: 1px solid rgba(255,255,255,0.07);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      color: #eef3ff;
      box-shadow: 0 14px 30px rgba(0,0,0,0.18);
    }

    .action-secondary::before {
      content: "";
      position: absolute;
      left: 0;
      top: 12px;
      bottom: 12px;
      width: 2px;
      background: linear-gradient(180deg, rgba(142,168,255,0.28), rgba(255,240,199,0.16));
    }

    .action-note { margin: 0; color: var(--soft-text); line-height: 1.58; font-size: 0.93rem; }

    .context-panel { display: grid; gap: 0.95rem; padding: 1rem; align-content: start; }
    .context-card { display: grid; gap: 0.75rem; padding: 0.95rem 1rem; border-radius: 18px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); }
    .context-card h3 { margin: 0; color: #fff; font-size: 1.05rem; }
    .context-card p { margin: 0; color: var(--soft-text); line-height: 1.55; font-size: 0.92rem; }
    .context-card.danger { background: linear-gradient(180deg, rgba(72,24,30,0.3), rgba(14,10,16,0.92)); border-color: rgba(255,140,140,0.14); }
    .context-card.breakthrough { background: linear-gradient(180deg, rgba(54,46,22,0.24), rgba(12,10,15,0.92)); border-color: rgba(255,240,199,0.14); }
    .context-card.cooldown { background: linear-gradient(180deg, rgba(54,34,16,0.24), rgba(12,10,15,0.92)); border-color: rgba(255,190,105,0.14); }

    .context-list { display: grid; gap: 0.65rem; }
    .context-row { display: flex; justify-content: space-between; gap: 0.8rem; color: var(--soft-text); font-size: 0.92rem; }
    .context-row span:first-child { color: var(--dim-text); }
    .context-row strong { text-align: right; color: #fff; }

    .record-footer-band {
      display: grid;
      gap: 1rem;
      padding: 1rem;
      background: linear-gradient(90deg, rgba(255,240,199,0.03), rgba(255,240,199,0.07), rgba(255,240,199,0.03));
    }

    .record-footer-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .record-footer-head h2 { margin: 0.2rem 0 0; color: #fff; font-size: 1.35rem; }
    .record-footer-head p { margin: 0.3rem 0 0; color: var(--soft-text); font-size: 0.95rem; }

    .breakthrough-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 0.85rem;
    }

    .breakthrough-chip {
      padding: 0.95rem 1rem;
      border-radius: 16px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .breakthrough-chip span {
      display: block;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(242,233,206,0.7);
    }

    .breakthrough-chip strong {
      display: block;
      margin-top: 0.28rem;
      color: #fff2c7;
      font-size: 1rem;
      line-height: 1.35;
    }

    .breakthrough-actions {
      display: none;
      gap: 0.8rem;
      padding-top: 0.15rem;
      align-items: start;
    }

    .breakthrough-actions.active {
      display: grid;
    }

    .breakthrough-entry-button {
      max-width: 340px;
      background: linear-gradient(135deg, #fff0c7, #ffbe69);
      color: #151007;
      box-shadow: 0 14px 30px rgba(255,190,105,0.24);
    }

    .breakthrough-entry-note {
      margin: 0;
      color: var(--soft-text);
      line-height: 1.58;
      font-size: 0.93rem;
    }

    .empty-state-panel {
      position: relative;
      display: grid;
      gap: 1rem;
      padding: 1.2rem 0 1rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0), rgba(255,255,255,0.02));
    }

    .empty-state-panel h2, .empty-state-panel p { margin: 0; padding: 0 0.15rem; }
    .empty-state-panel h2 { color: #fff; }
    .empty-state-panel p { color: var(--soft-text); line-height: 1.55; }
    .empty-state-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; padding: 0 0.15rem; }
    .empty-state-actions a { min-width: 180px; }
    .login-error {
      margin: 0;
      padding: 0.85rem 1rem;
      border-top: 1px solid rgba(218,114,114,0.38);
      border-bottom: 1px solid rgba(218,114,114,0.22);
      background: linear-gradient(180deg, rgba(90,22,22,0.26), rgba(52,14,14,0.18));
      color: rgba(255,222,222,0.92);
      line-height: 1.55;
    }

    @keyframes altarSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes altarPulse { 0%,100% { transform: scale(1); filter: brightness(0.96); } 50% { transform: scale(1.03); filter: brightness(1.08); } }
    @keyframes fracturePulse { 0%,100% { opacity: 0.45; } 50% { opacity: 0.95; } }
    @keyframes floatParticle {
      0% { transform: translateY(18px) scale(0.8); opacity: 0; }
      18% { opacity: 0.85; }
      100% { transform: translateY(-170px) scale(1.15); opacity: 0; }
    }

    @media (max-width: 1180px) {
      .vessel-gate-panel { grid-template-columns: 1fr; }
      .record-lower-grid { grid-template-columns: 1fr; }
      .breakthrough-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
    }

    @media (max-width: 740px) {
      .record-page { width: min(100% - 1rem, 1380px); margin-top: 1rem; }
      .record-hero { min-height: 258px; padding: 1.2rem 1rem 1.1rem; border-radius: 16px; }
      .altar-progress-grid, .breakthrough-grid { grid-template-columns: 1fr; }
      .empty-state-actions { flex-direction: column; }
      .empty-state-actions a { width: 100%; }
      .breakthrough-entry-button { max-width: none; width: 100%; }
    }
  </style>
</head>
<body>
  <div class="cloud-layer"></div>
  <div class="rune-layer"></div>
  <div class="lightning-flash"></div>

  <nav>
    <a href="/index.html">Home</a>
    <a href="/lore.html">Lore</a>
    <a href="/dashboard.html">Dashboard</a>
    <a href="/library.html">Library</a>
    <a href="/cultivation.html" class="active">Cultivation</a>
    <a href="/.netlify/functions/logout" id="logout-button">Logout</a>
  </nav>

  <main class="record-page">
    <section class="record-hero">
      <span class="hero-kicker" id="hero-kicker">Opened Record</span>
      <div class="hero-top-row">
        <div class="hero-title-wrap">
          <h1 id="hero-title">Loading record...</h1>
          <p class="hero-subtitle" id="hero-subtitle">Preparing the opened record...</p>
        </div>
        <div class="hero-state-badge idle" id="hero-state-badge">Preparing</div>
      </div>
      <div class="hero-meta-row">
        <div class="hero-meta-pill" id="hero-volume-pill">Volume --</div>
        <div class="hero-meta-pill" id="hero-realm-pill">Loading realm...</div>
        <div class="hero-meta-pill" id="hero-focus-pill">No active focus</div>
      </div>
    </section>

    <p id="page-message" class="summary is-hidden hero-message"></p>

    <section id="main-shell">
      <div class="vessel-gate-panel" id="vessel-gate-panel">
        <div class="vessel-side" id="vessel-side">
          <div class="vessel-side-head">
            <p class="vessel-side-kicker" id="vessel-side-kicker">Cultivator Vessel</p>
            <h2 class="vessel-side-title" id="vessel-side-title">Meditating</h2>
          </div>
          <div class="vessel-canvas-wrap">
            <canvas id="vessel-canvas" width="400" height="400"></canvas>
          </div>
          <div class="vessel-qi-bar-wrap">
            <p class="vessel-qi-bar-label">Qi Reserve <span id="vessel-qi-label">0%</span></p>
            <div class="vessel-qi-bar-track"><div class="vessel-qi-bar-fill" id="vessel-qi-bar-fill"></div></div>
          </div>
        </div>
        <div class="gate-side" id="gate-side">
          <div class="gate-wrap" id="gate-wrap">
            <div class="gate-header">
              <p class="gate-kicker" id="gate-kicker">Ascension Threshold</p>
              <h2 class="gate-title" id="gate-title">Gate Sealed</h2>
              <p class="gate-desc" id="gate-desc">This section has not yet been opened.</p>
            </div>
            <div class="gate-scene" id="gate-scene">
              <div id="gate-bg"></div>
              <div id="gate-qi-layer"></div>
              <div id="gate-spark-layer"></div>
              <div class="gate-flash" id="gate-flash"></div>
              <div class="gate-archway">
                <div class="gate-arch-top" id="gate-arch-top">
                  <span class="gate-rune" id="gate-rune-l">&#x2B21;</span>
                  <span class="gate-rune" id="gate-rune-m">&#x2630;</span>
                  <span class="gate-rune" id="gate-rune-r">&#x2B21;</span>
                </div>
                <div class="gate-arch-pillar-l" id="gate-pillar-l"></div>
                <div class="gate-arch-pillar-r" id="gate-pillar-r"></div>
                <div class="gate-beam" id="gate-beam"></div>
                <div class="gate-door-l" id="gate-door-l">
                  <div class="gate-door-panel" id="gate-door-panel-l">
                    <div class="gate-door-inner" id="gate-door-inner-l"></div>
                  </div>
                </div>
                <div class="gate-door-r" id="gate-door-r">
                  <div class="gate-door-panel" id="gate-door-panel-r">
                    <div class="gate-door-inner" id="gate-door-inner-r"></div>
                  </div>
                </div>
                <div class="gate-seam" id="gate-seam"></div>
                <div class="gate-progress-bar-wrap" id="gate-progress-wrap" style="display:none;">
                  <div class="gate-progress-bar-fill" id="gate-progress-fill"></div>
                </div>
              </div>
              <canvas class="gate-figure" id="gate-figure" style="display:none;"></canvas>
              <div class="gate-floor" id="gate-floor"></div>
            </div>
            <div class="gate-footer">
              <div class="gate-chips" id="gate-chips"></div>
              <button class="gate-action-btn" id="gate-action-btn" style="display:none;"></button>
              <div class="gate-action-btn-off" id="gate-action-btn-off" style="display:none;"></div>
              <p class="gate-sub-note" id="gate-sub-note"></p>
            </div>
          </div>
        </div>
      </div>

      <div class="record-stats-bar" id="record-stats-bar">
        <div class="record-stats-row">
          <div class="record-stat-box"><span>Progress</span><strong id="altar-progress-value">0%</strong></div>
          <div class="record-stat-box"><span>Remaining</span><strong id="altar-remaining-value">0m</strong></div>
          <div class="record-stat-box"><span>Qi State</span><strong id="altar-qi-value">0 / 0</strong></div>
          <div class="record-stat-box"><span>Cult. Points</span><strong id="stat-cp-value">0</strong></div>
        </div>
        <div class="action-well">
          <button class="action-primary" id="primary-action-button" aria-disabled="true">Loading...</button>
          <a href="/cultivation.html" class="action-secondary" id="secondary-action-button">Meditation Page</a>
          <p class="action-note" id="action-note">Checking the next valid altar action...</p>
        </div>
      </div>

      <div class="record-lower-grid">
        <section class="record-panel path-panel">
          <div class="record-panel-head">
            <p class="record-panel-kicker">Section Path</p>
            <h2 class="record-panel-title">Cultivation Route</h2>
            <p class="record-panel-subtitle">Each section reflects live backend truth: sealed, opened, active, damaged, breakthrough-gated, or complete.</p>
          </div>
          <div class="path-list" id="path-list"></div>
        </section>
        <section class="record-panel context-panel">
          <div class="record-panel-head">
            <p class="record-panel-kicker">Condition Panel</p>
            <h2 class="record-panel-title" id="context-title">Current Condition</h2>
            <p class="record-panel-subtitle">Damage, breakthrough gates, cooldown, and study flow appear here.</p>
          </div>
          <div id="context-root"></div>
        </section>
      </div>
    </section>

    <div id="empty-root"></div>
  </main>

  <footer>The Ascendant Path • Opened Record Interface</footer>

  <script>
    const LOGIN_URL = "https://ascendantpath.org/login.html";
    const VERIFY_SESSION_ENDPOINT = "/.netlify/functions/verify-session";
    const LOGOUT_ENDPOINT = "/.netlify/functions/logout";
    const DASHBOARD_ENDPOINT = "/.netlify/functions/load-dashboard-state";
    const MEMBER_STATE_ENDPOINT = "/.netlify/functions/load-member-state";
    const BOOK_STATE_ENDPOINT = "/.netlify/functions/load-cultivation-book-state";

    const state = {
      member: null,
      user: null,
      record: null,
      requestedVolumeNumber: null,
      actionState: null,
      actionPending: false,
      refreshInFlight: false,
      cosmeticTickInterval: null,
      refreshInterval: null,
      displayRemainingSeconds: 0,
      displayIsActive: false
    };

    const SECTION_KEYS = ["base", "early", "middle", "late"];
    const REALM_SEQUENCE = [
      "Mortal Realm",
      "Qi Gathering Realm",
      "Foundation Realm",
      "Core Formation Realm",
      "Nascent Soul Realm",
      "Soul Transformation Realm",
      "Void Refinement Realm",
      "Body Integration Realm",
      "Mahayana Realm",
      "Tribulation Realm"
    ];

    function safeText(value, fallback = "") {
      const text = String(value ?? "").trim();
      return text || fallback;
    }

    function safeLower(value) {
      return safeText(value).toLowerCase();
    }

    function safeNumber(value, fallback = 0) {
      const num = Number(value);
      return Number.isFinite(num) ? num : fallback;
    }

    function safeBoolean(value, fallback = false) {
      if (typeof value === "boolean") return value;
      if (typeof value === "number") return value !== 0;
      const text = safeLower(value);
      if (["true", "1", "yes", "y", "on", "active"].includes(text)) return true;
      if (["false", "0", "no", "n", "off", "inactive"].includes(text)) return false;
      return fallback;
    }

    function safeUpper(value) {
      return safeText(value).toUpperCase();
    }

    function toTitle(value, fallback = "Unknown") {
      const text = safeLower(value);
      if (!text) return fallback;
      return text
        .replace(/[_-]+/g, " ")
        .split(" ")
        .filter(Boolean)
        .map(part => part.charAt(0).toUpperCase() + part.slice(1))
        .join(" ");
    }

    function formatDuration(totalSeconds) {
      const seconds = Math.max(0, Math.floor(safeNumber(totalSeconds, 0)));
      const hours = Math.floor(seconds / 3600);
      const minutes = Math.floor((seconds % 3600) / 60);
      const secs = seconds % 60;

      if (hours > 0) return hours + "h " + minutes + "m";
      if (minutes > 0) return minutes + "m " + secs + "s";
      return secs + "s";
    }

    function realmFromVolume(volumeNumber) {
      const value = safeNumber(volumeNumber, 0);
      return value >= 1 && value <= REALM_SEQUENCE.length
        ? REALM_SEQUENCE[value - 1]
        : "Unknown Realm";
    }

    function getVolumeFromQuery() {
      const raw = new URLSearchParams(window.location.search).get("volume");
      const parsed = Number(raw);
      return Number.isInteger(parsed) && parsed > 0 ? parsed : null;
    }

    function syncVolumeQuery(volumeNumber) {
      const url = new URL(window.location.href);

      if (safeNumber(volumeNumber, 0) > 0) {
        url.searchParams.set("volume", String(volumeNumber));
      } else {
        url.searchParams.delete("volume");
      }

      window.history.replaceState({}, "", url.toString());
    }

    function getCsrfToken() {
      return sessionStorage.getItem("ap_csrf_token") || "";
    }

    function setCsrfToken(token) {
      const value = safeText(token, "");
      if (value) {
        sessionStorage.setItem("ap_csrf_token", value);
      }
    }

    function clearClientSessionArtifacts() {
      sessionStorage.removeItem("ap_csrf_token");
      localStorage.removeItem("session_token");
    }

    function redirectToLogin() {
      const next = `${window.location.pathname}${window.location.search}${window.location.hash}`;
      window.location.href = `${LOGIN_URL}?next=${encodeURIComponent(next)}`;
    }

    function setMessage(text, tone = "info") {
      const el = document.getElementById("page-message");

      if (!text) {
        el.textContent = "";
        el.className = "summary is-hidden hero-message";
        return;
      }

      el.textContent = text;
      el.className = tone === "error" ? "login-error hero-message" : "summary hero-message";
    }

    async function requireAuth() {
      try {
        const response = await fetch(VERIFY_SESSION_ENDPOINT, {
          method: "GET",
          credentials: "include",
          headers: {
            "Accept": "application/json"
          }
        });

        if (response.status === 401) {
          clearClientSessionArtifacts();
          redirectToLogin();
          return null;
        }

        if (!response.ok) {
          throw new Error(`verify_session_failed_${response.status}`);
        }

        const data = await response.json();

        if (!data || data.authenticated !== true) {
          clearClientSessionArtifacts();
          redirectToLogin();
          return null;
        }

        const csrfToken =
          data.csrf_token ||
          data.csrfToken ||
          data.csrf ||
          "";

        if (csrfToken) {
          setCsrfToken(csrfToken);
        }

        return data;
      } catch (error) {
        console.error("Cultivation auth verification error:", error);
        clearClientSessionArtifacts();
        redirectToLogin();
        return null;
      }
    }

    async function logoutCurrentSession() {
      const csrfToken = getCsrfToken();

      try {
        await fetch(LOGOUT_ENDPOINT, {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json",
            ...(csrfToken ? { "X-AP-CSRF-Token": csrfToken } : {})
          },
          body: JSON.stringify({})
        });
      } catch (error) {
        console.error("Cultivation logout error:", error);
      } finally {
        clearClientSessionArtifacts();
        window.location.href = LOGIN_URL;
      }
    }

    function bindLogoutButton() {
      const logoutButton = document.getElementById("logout-button");
      if (!logoutButton) return;

      logoutButton.addEventListener("click", async (event) => {
        event.preventDefault();
        await logoutCurrentSession();
      });
    }

    async function fetchJson(url, options = {}) {
      const response = await fetch(url, {
        credentials: "include",
        headers: {
          Accept: "application/json",
          ...(options.headers || {})
        },
        ...options
      });

      const text = await response.text();
      let payload = null;

      try {
        payload = text ? JSON.parse(text) : null;
      } catch {
        payload = null;
      }

      if (response.status === 401) {
        clearClientSessionArtifacts();
        redirectToLogin();
        throw new Error("unauthorized");
      }

      if (!response.ok) {
        throw new Error(payload?.error || payload?.message || `request_failed_${response.status}`);
      }

      return payload;
    }

    function getRecord() {
      return state.record || null;
    }

    function getStore() {
      return getRecord()?.store_volume || null;
    }

    function getSections() {
      return getRecord()?.sections || {};
    }

    function getFocusRecord() {
      return getRecord()?.focus_section_record || null;
    }

    function getAccess() {
      return getRecord()?.access || null;
    }

    function getUi() {
      return getRecord()?.ui || {};
    }

    function getPrimaryActionPayload() {
      return getUi()?.primary_action || null;
    }

    function getBookUiState() {
      return safeLower(getUi()?.book_ui_state || "sealed");
    }

    function getBreakthroughUi() {
      return getUi()?.breakthrough || {};
    }

    function breakthroughControlsFlow() {
      return safeBoolean(getBreakthroughUi()?.controls_flow, false);
    }

    function getBreakthroughDisplayState() {
      return safeText(getBreakthroughUi()?.display_state, "Not Manifest");
    }

    function getBreakthroughDisplayMessage() {
      return safeText(
        getBreakthroughUi()?.display_message,
        "No active breakthrough target is currently attached to this record."
      );
    }

    function getBreakthroughRoute() {
      const explicitRoute = safeText(getBreakthroughUi()?.route);
      if (explicitRoute) return explicitRoute;

      const storeVolume = safeNumber(getStore()?.volume_number, 0);
      const requestedVolume = safeNumber(state.requestedVolumeNumber, 0);
      const volumeNumber = storeVolume || requestedVolume || 0;

      return "/breakthrough.html?volume=" + encodeURIComponent(volumeNumber);
    }

    function isBreakthroughUiState(value) {
      return [
        "breakthrough_pending",
        "breakthrough_active",
        "breakthrough_ready",
        "breakthrough_cooldown"
      ].includes(safeLower(value));
    }

    function sectionNeedsBreakthrough(sectionData) {
      return isBreakthroughUiState(sectionData?.ui_state);
    }

    function getBreakthroughSectionRecord() {
      const focus = getFocusRecord();
      if (sectionNeedsBreakthrough(focus)) return focus;

      const sections = getSections();
      for (const key of SECTION_KEYS) {
        if (sectionNeedsBreakthrough(sections[key])) {
          return sections[key];
        }
      }

      return null;
    }

    function hasBreakthroughEligibleSection() {
      return !!getBreakthroughSectionRecord();
    }

    function shouldShowBreakthroughEntry() {
      const breakthroughUi = getBreakthroughUi();

      return (
        breakthroughControlsFlow() ||
        hasBreakthroughEligibleSection() ||
        safeBoolean(breakthroughUi?.can_enter, false) ||
        safeBoolean(breakthroughUi?.available, false)
      );
    }

    function getBottomBreakthroughMessage() {
      const section = getBreakthroughSectionRecord();

      if (breakthroughControlsFlow()) {
        return getBreakthroughDisplayMessage();
      }

      if (section) {
        return safeText(
          section.ui_note,
          "A breakthrough threshold is active for this record. Enter the chamber to continue."
        );
      }

      return "A breakthrough threshold is active for this record. Enter the chamber to continue.";
    }

    function getBottomBreakthroughStateLabel() {
      const section = getBreakthroughSectionRecord();

      if (breakthroughControlsFlow()) {
        return getBreakthroughDisplayState();
      }

      if (section) {
        return formatSectionUiState(section.ui_state);
      }

      return "Threshold Available";
    }

    function adoptServerSelectedVolume(recordPayload) {
      const selectedVolumeNumber = safeNumber(recordPayload?.selected_volume_number, 0);
      if (selectedVolumeNumber <= 0) return;

      state.requestedVolumeNumber = selectedVolumeNumber;
      syncVolumeQuery(selectedVolumeNumber);
    }

    function getV2CultivationStatus() {
      return safeLower(
        state.user?.v2_cultivation_status ||
        state.member?.v2_cultivation_status ||
        "idle"
      );
    }

    function formatSectionUiState(uiState) {
      const key = safeLower(uiState);

      if (key === "sealed") return "Sealed";
      if (key === "open") return "Opened";
      if (key === "cultivating") return "Cultivating";
      if (key === "paused") return "Paused";
      if (key === "complete") return "Ready to Complete";
      if (key === "damaged") return "Damaged";
      if (key === "comprehended") return "Comprehended";
      if (key === "breakthrough_pending") return "Breakthrough Required";
      if (key === "breakthrough_active") return "Breakthrough In Progress";
      if (key === "breakthrough_ready") return "Verdict Ready";
      if (key === "breakthrough_cooldown") return "Cooldown";

      return toTitle(key, "Unknown");
    }

    function getSectionNote(sectionData) {
      const uiState = safeLower(sectionData?.ui_state);

      if (uiState === "damaged") {
        return safeText(sectionData?.ui_note, "Repair required before the record can continue.");
      }

      if (uiState === "complete") {
        return safeText(sectionData?.ui_note, "Required cultivation time has been met. This section can now be completed.");
      }

      if (uiState === "cultivating") {
        return safeText(sectionData?.ui_note, "Realm Cultivation is actively feeding this section.");
      }

      if (uiState === "paused") {
        return safeText(sectionData?.ui_note, "Cultivation is paused. Resume when ready.");
      }

      if (uiState === "open") {
        return safeText(sectionData?.ui_note, "Opened and ready to begin comprehension.");
      }

      if (uiState === "comprehended") {
        return safeText(sectionData?.ui_note, "This section has been fully comprehended.");
      }

      if (
        uiState === "breakthrough_pending" ||
        uiState === "breakthrough_active" ||
        uiState === "breakthrough_ready" ||
        uiState === "breakthrough_cooldown"
      ) {
        return safeText(sectionData?.ui_note || getBreakthroughDisplayMessage(), "Breakthrough currently governs this section.");
      }

      if (uiState === "sealed") {
        const cost = safeNumber(sectionData?.open_cp_cost, 0);
        const fallback = cost > 0
          ? "Sealed until its turn in the cultivation path. Unlock cost: " + cost + " CP."
          : "Sealed until its turn in the cultivation path.";
        return safeText(sectionData?.ui_note, fallback);
      }

      return safeText(sectionData?.ui_note, "");
    }

    function renderHero() {
      const store = getStore();
      const focus = getFocusRecord();
      const ui = getUi();
      const bookUiState = getBookUiState();

      document.getElementById("hero-title").textContent = safeText(store?.item_name, "Cultivation Record");
      document.getElementById("hero-subtitle").textContent =
        safeText(ui?.message) ||
        safeText(store?.description) ||
        "Preparing the opened record...";

      document.getElementById("hero-volume-pill").textContent =
        "Volume " + (safeNumber(store?.volume_number, 0) || "--");

      document.getElementById("hero-realm-pill").textContent =
        safeText(store?.realm_name, realmFromVolume(store?.volume_number));

      document.getElementById("hero-focus-pill").textContent = focus
        ? "Focus • " + toTitle(focus.section_key, "Section")
        : "No active focus";

      const badgeMap = {
        cultivating: { key: "cultivating", label: "Cultivating" },
        paused: { key: "paused", label: "Paused" },
        damaged: { key: "damaged", label: "Damaged Record" },
        breakthrough_pending: { key: "breakthrough", label: getBreakthroughDisplayState() || "Breakthrough" },
        breakthrough_active: { key: "breakthrough", label: getBreakthroughDisplayState() || "Breakthrough" },
        breakthrough_ready: { key: "breakthrough", label: getBreakthroughDisplayState() || "Breakthrough" },
        breakthrough_cooldown: { key: "cooldown", label: getBreakthroughDisplayState() || "Cooldown" },
        complete: { key: "complete", label: "Ready to Complete" },
        comprehended: { key: "complete", label: "Volume Completed" },
        reopened: { key: "reopened", label: "Resumed Record" },
        open: { key: "idle", label: "Awaiting Action" },
        sealed: { key: "idle", label: "Awaiting Action" }
      };

      const resolved = badgeMap[bookUiState] || { key: "idle", label: "Awaiting Action" };
      const badge = document.getElementById("hero-state-badge");
      badge.textContent = resolved.label;
      badge.className = "hero-state-badge " + resolved.key;
    }

    function renderPath() {
      try {
        var store = getStore();
        var pathList = document.getElementById('path-list');
        if (!pathList) return;
        var sectionsObj = state.record && state.record.sections ? state.record.sections : {};
        var sections = Object.values(sectionsObj);
        if (!sections.length) {
          pathList.innerHTML = '<p style="color:rgba(255,255,255,0.3);font-size:13px;">No sections available.</p>';
          return;
        }
        pathList.innerHTML = sections.map(function(s, idx) {
          var status = safeLower(s.stage_status || s.ui_state || '');
          var isActive = status === 'cultivating' || status === 'active';
          var isDone = status === 'comprehended' || status === 'complete';
          var isDamaged = status === 'damaged' || status === 'needs_repair';
          var isReady = status === 'breakthrough_ready';
          var pct = s.required_seconds > 0 ? Math.min(100, Math.round((safeNumber(s.accumulated_seconds,0)/safeNumber(s.required_seconds,1))*100)) : 0;
          var badgeColor = isDone ? '#6acc6a' : isActive ? '#6aaccc' : isDamaged ? '#cc4444' : isReady ? '#c8a96a' : 'rgba(255,255,255,0.3)';
          var badgeBg = isDone ? '#1a2a1a' : isActive ? '#0d1a24' : isDamaged ? '#2a0d0d' : isReady ? '#1a1400' : 'rgba(255,255,255,0.05)';
          var badgeBorder = isDone ? '#3a6a3a55' : isActive ? '#3a608055' : isDamaged ? '#7a202055' : isReady ? '#c8a96a55' : 'rgba(255,255,255,0.08)';
          var nodeId = 'path-node-'+idx;
          var expanded = isActive || isDamaged ? 'true' : 'false';
          return '<div class="path-node-wrap" id="'+nodeId+'">'
            +'<div class="path-node-header" onclick="togglePathNode(\''+nodeId+'\')" style="cursor:pointer;display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:rgba(255,255,255,0.04);border:0.5px solid rgba(255,255,255,0.06);border-radius:8px;margin-bottom:4px;">'
            +'<div style="flex:1;">'
            +'<p style="font-size:13px;font-weight:500;color:#fff;margin:0 0 1px;">'+toTitle(s.section_key||s.key||'Section')+'</p>'
            +'<p style="font-size:11px;color:rgba(255,255,255,0.35);margin:0;">'+safeText(s.book_title||s.title,'')+'</p>'
            +'</div>'
            +'<div style="display:flex;align-items:center;gap:8px;">'
            +'<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:10px;background:'+badgeBg+';color:'+badgeColor+';border:0.5px solid '+badgeBorder+';">'+toTitle(status||'Sealed')+'</span>'
            +'<span class="path-node-arrow" style="font-size:10px;color:rgba(255,255,255,0.3);transition:transform 0.2s;">&#x25BC;</span>'
            +'</div>'
            +'</div>'
            +'<div class="path-node-body" data-expanded="'+expanded+'" style="display:'+(expanded==='true'?'block':'none')+';padding:8px 12px 10px;background:rgba(255,255,255,0.02);border:0.5px solid rgba(255,255,255,0.05);border-top:none;border-radius:0 0 8px 8px;margin-bottom:6px;">'
            +'<div style="height:3px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;margin-bottom:8px;">'
            +'<div style="height:100%;width:'+pct+'%;background:'+badgeColor+';border-radius:2px;transition:width 0.8s ease;"></div>'
            +'</div>'
            +'<div style="display:flex;justify-content:space-between;font-size:11px;">'
            +'<span style="color:rgba(255,255,255,0.4);">'+pct+'%</span>'
            +'<span style="color:rgba(255,255,255,0.4);">'+(s.human_remaining||s.remaining_display||'')+'</span>'
            +'</div>'
            +(isDamaged?'<p style="font-size:11px;color:#cc4444;margin:6px 0 0;">Repair cost: '+safeNumber(s.repair_cp_cost,0)+' CP</p>':'')
            +(s.ui_note?'<p style="font-size:11px;color:rgba(255,255,255,0.4);margin:6px 0 0;">'+safeText(s.ui_note)+'</p>':'')
            +'</div>'
            +'</div>';
        }).join('');
      } catch(e) {
        console.error('renderPath error:', e);
      }
    }

    function togglePathNode(nodeId) {
      try {
        var wrap = document.getElementById(nodeId);
        if (!wrap) return;
        var body = wrap.querySelector('.path-node-body');
        var arrow = wrap.querySelector('.path-node-arrow');
        if (!body) return;
        var isOpen = body.getAttribute('data-expanded') === 'true';
        body.setAttribute('data-expanded', isOpen ? 'false' : 'true');
        body.style.display = isOpen ? 'none' : 'block';
        if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
      } catch(e) {}
    }

    function syncCosmeticTimer() {
      const focus = getFocusRecord();
      state.displayIsActive = getV2CultivationStatus() === "cultivating" && !!focus;
      state.displayRemainingSeconds = safeNumber(focus?.remaining_seconds, 0);
    }

    function renderAltar() {
      try {
        var focus = getFocusRecord();
        var progress = focus ? safeNumber(focus.progress_pct, 0) : 0;
        var displayedRemaining = state.displayIsActive && state.displayRemainingSeconds > 0
          ? formatDuration(state.displayRemainingSeconds)
          : (focus ? safeText(focus.human_remaining, '0m') : '0m');
        var qiCurrent = safeNumber(state.user && state.user.qi_current || state.member && state.member.qi_current, 0);
        var qiMax = safeNumber(state.user && state.user.qi_maximum || state.member && state.member.qi_maximum, 0);
        var cp = safeNumber(state.user && state.user.cultivation_points || state.member && state.member.cultivation_points, 0);
        var progressEl = document.getElementById('altar-progress-value');
        var remainEl   = document.getElementById('altar-remaining-value');
        var qiEl       = document.getElementById('altar-qi-value');
        var cpEl       = document.getElementById('stat-cp-value');
        if (progressEl) progressEl.textContent = progress + '%';
        if (remainEl)   remainEl.textContent = displayedRemaining;
        if (qiEl)       qiEl.textContent = qiCurrent + ' / ' + qiMax;
        if (cpEl)       cpEl.textContent = cp.toLocaleString();
        if (_vesselRafId === null) runGateVessel();
      } catch(e) {
        console.error('renderAltar error:', e);
      }
    }

    function renderContext() {
      try {
        var focus = getFocusRecord();
        var store = getStore();
        var cards = [];
        var SECTION_KEYS = ['base','early','middle','late'];

        if (focus && safeLower(focus.ui_state) === 'damaged') {
          cards.push('<article class="context-card danger">'
            +'<h3>Tribulation Damage</h3>'
            +'<p>'+safeText(focus.ui_note, 'This section was struck by tribulation. Repair to resume.')+'</p>'
            +'<div class="context-list">'
            +'<div class="context-row"><span>Section</span><strong>'+toTitle(focus.section_key)+'</strong></div>'
            +'<div class="context-row"><span>Repair Cost</span><strong>'+safeNumber(focus.repair_cp_cost,0)+' CP</strong></div>'
            +'<div class="context-row"><span>Resume From</span><strong>'+(safeNumber(focus.repair_resume_from_seconds,0)>0?formatDuration(focus.repair_resume_from_seconds):'--')+'</strong></div>'
            +'</div></article>');
        }

        var sectionsObj = state.record && state.record.sections ? state.record.sections : {};
        var sections = Object.values(sectionsObj);
        if (sections.length > 0) {
          var sectionRows = sections.map(function(s) {
            var statusColor = {
              comprehended: '#6acc6a', complete: '#6acc6a',
              cultivating: '#6aaccc', active: '#6aaccc',
              damaged: '#cc4444', needs_repair: '#cc4444',
              breakthrough_ready: '#c8a96a', open: 'rgba(255,255,255,0.5)',
              sealed: 'rgba(255,255,255,0.2)', locked: 'rgba(255,255,255,0.2)'
            }[safeLower(s.stage_status||s.ui_state||'')] || 'rgba(255,255,255,0.5)';
            var pct = s.required_seconds > 0 ? Math.min(100, Math.round((safeNumber(s.accumulated_seconds,0)/safeNumber(s.required_seconds,1))*100)) : 0;
            return '<div class="context-row">'
              +'<span>'+toTitle(s.section_key||s.key||'')+'</span>'
              +'<strong style="color:'+statusColor+';">'+toTitle(s.stage_status||s.ui_state||'--')+' ('+pct+'%)</strong>'
              +'</div>';
          }).join('');
          cards.push('<article class="context-card">'
            +'<h3>Book Health</h3>'
            +'<div class="context-list">'+sectionRows+'</div>'
            +'</article>');
        }

        if (breakthroughControlsFlow()) {
          var btState = safeLower(getBreakthroughDisplayState());
          var btColor = btState.includes('cooldown') ? '#e8a840' : '#c8a96a';
          cards.push('<article class="context-card breakthrough">'
            +'<h3>Breakthrough State</h3>'
            +'<p>'+getBreakthroughDisplayMessage()+'</p>'
            +'<div class="context-list">'
            +'<div class="context-row"><span>Chamber</span><strong style="color:'+btColor+';">'+getBreakthroughDisplayState()+'</strong></div>'
            +'</div></article>');
        }

        var contextTitle = document.getElementById('context-title');
        if (contextTitle) contextTitle.textContent = 'Book State';
        var contextRoot = document.getElementById('context-root');
        if (contextRoot) contextRoot.innerHTML = cards.length ? cards.join('') : '<p style="color:rgba(255,255,255,0.3);font-size:13px;padding:0.5rem 0;">No state data available.</p>';
      } catch(e) {
        console.error('renderContext error:', e);
      }
    }

    var _vesselRafId = null;
    var _vesselT = 0;
    var _vesselFigCache = { male: null, female: null };
    var _vesselFigLoading = false;
    var _vesselFigCallbacks = [];
    var _vesselCurrentColor = '#c8a96a';
    var _vesselGenderColor = { male: '#c8a96a', female: '#c86890' };
    var _vesselCurrentQiPct = 0;

    function getAlignmentColors(pathCurrent) {
      var p = (pathCurrent || '').toLowerCase();
      if (p === 'yin') return { fillA:'rgba(140,180,220,0.7)', fillB:'rgba(80,120,200,0.3)', glow:'rgba(140,180,255,0.35)', wave:'rgba(180,210,255,0.6)', type:'yin' };
      if (p === 'yang') return { fillA:'rgba(240,160,40,0.75)', fillB:'rgba(200,80,20,0.3)', glow:'rgba(255,160,40,0.4)', wave:'rgba(255,200,80,0.7)', type:'yang' };
      if (p === 'taiji') return { fillA:'rgba(200,169,106,0.7)', fillB:'rgba(200,104,144,0.3)', glow:'rgba(200,169,106,0.3)', wave:'rgba(255,220,140,0.6)', type:'taiji' };
      return { fillA:'rgba(200,169,106,0.7)', fillB:'rgba(160,120,60,0.3)', glow:'rgba(200,169,106,0.3)', wave:'rgba(255,220,140,0.6)', type:'default' };
    }

    function loadVesselFigure(gender, callback) {
      if (_vesselFigCache[gender] !== null) { callback(_vesselFigCache[gender]); return; }
      _vesselFigCallbacks.push(callback);
      if (_vesselFigLoading) return;
      _vesselFigLoading = true;
      var url = (gender === 'female') ? '/female-figure.svg' : '/figure.svg';
      var img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = function() {
        try {
          var off = document.createElement('canvas');
          off.width = 1024; off.height = 1024;
          var ctx2 = off.getContext('2d');
          ctx2.drawImage(img, 0, 0);
          var id = ctx2.getImageData(0, 0, 1024, 1024);
          var d = id.data;
          var _figRGB = (gender === 'female') ? [200, 104, 144] : [200, 169, 106];
          for (var i = 0; i < d.length; i += 4) {
            if (d[i+3] > 10 && d[i] < 80 && d[i+1] < 80 && d[i+2] < 80) {
              d[i] = _figRGB[0]; d[i+1] = _figRGB[1]; d[i+2] = _figRGB[2];
            } else { d[i+3] = 0; }
          }
          ctx2.putImageData(id, 0, 0);
          _vesselFigCache[gender] = off;
        } catch(e) { _vesselFigCache[gender] = null; }
        _vesselFigLoading = false;
        var cbs = _vesselFigCallbacks.slice(); _vesselFigCallbacks = [];
        for (var j = 0; j < cbs.length; j++) { cbs[j](_vesselFigCache[gender]); }
      };
      img.onerror = function() {
        _vesselFigCache[gender] = null; _vesselFigLoading = false;
        var cbs = _vesselFigCallbacks.slice(); _vesselFigCallbacks = [];
        for (var j = 0; j < cbs.length; j++) { cbs[j](null); }
      };
      img.src = url;
    }

    function drawVesselQiAura(ctx, cx, cy, baseR, pct, c1, c2, t, start) {
      if (pct <= 0) return;
      var end = start + Math.PI * 2 * pct;

      var haloR = baseR + 28 + Math.sin(t * 0.8) * 8;
      ctx.save();
      ctx.beginPath(); ctx.arc(cx, cy, haloR, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(200,169,106,0.04)'; ctx.globalAlpha = 1; ctx.fill();
      ctx.restore();

      ctx.save();
      ctx.beginPath(); ctx.arc(cx, cy, baseR, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 14; ctx.stroke();
      ctx.restore();

      ctx.save();
      ctx.beginPath(); ctx.arc(cx, cy, baseR, start, end);
      ctx.strokeStyle = c1; ctx.lineWidth = 22;
      ctx.globalAlpha = 0.18 + Math.sin(t * 1.2) * 0.06;
      ctx.lineCap = 'round'; ctx.stroke();
      ctx.restore();

      ctx.save();
      ctx.beginPath(); ctx.arc(cx, cy, baseR, start, end);
      ctx.strokeStyle = c2; ctx.lineWidth = 12;
      ctx.globalAlpha = 0.35 + Math.sin(t * 1.5) * 0.1;
      ctx.lineCap = 'round'; ctx.stroke();
      ctx.restore();

      ctx.save();
      ctx.beginPath(); ctx.arc(cx, cy, baseR, start, end);
      ctx.strokeStyle = c1; ctx.lineWidth = 4;
      ctx.globalAlpha = 0.92; ctx.lineCap = 'round'; ctx.stroke();
      ctx.restore();

      var innerR = baseR - 18;
      var innerEnd = start + Math.PI * 2 * pct * 0.95 + Math.sin(t * 0.4) * 0.08;
      ctx.save();
      ctx.beginPath(); ctx.arc(cx, cy, innerR, start, innerEnd);
      ctx.strokeStyle = c2; ctx.lineWidth = 2.5;
      ctx.globalAlpha = 0.5 + Math.sin(t * 2) * 0.2;
      ctx.lineCap = 'round'; ctx.stroke();
      ctx.restore();

      var particleCount = Math.floor(pct * 14) + 3;
      for (var i = 0; i < particleCount; i++) {
        var phase = (i / particleCount) * pct * Math.PI * 2 + t * (0.4 + i * 0.02);
        var drift = Math.sin(t * 2 + i * 1.3) * 7;
        var px = cx + Math.cos(start + phase) * (baseR + drift);
        var py = cy + Math.sin(start + phase) * (baseR + drift);
        var pSize = 1.5 + Math.sin(t * 3 + i) * 1;
        var pAlpha = 0.4 + Math.sin(t * 2.5 + i * 0.7) * 0.4;
        ctx.save();
        ctx.beginPath(); ctx.arc(px, py, pSize, 0, Math.PI * 2);
        ctx.fillStyle = i % 2 === 0 ? c1 : c2;
        ctx.globalAlpha = pAlpha; ctx.fill();
        ctx.restore();
      }

      var tipX = cx + Math.cos(end) * baseR;
      var tipY = cy + Math.sin(end) * baseR;
      var ripple = Math.sin(t * 4) * 0.5 + 0.5;
      ctx.save();
      ctx.beginPath(); ctx.arc(tipX, tipY, 10 + ripple * 5, 0, Math.PI * 2);
      ctx.fillStyle = c1; ctx.globalAlpha = 0.12 * ripple; ctx.fill();
      ctx.restore();
      ctx.save();
      ctx.beginPath(); ctx.arc(tipX, tipY, 5, 0, Math.PI * 2);
      ctx.fillStyle = '#ffffff'; ctx.globalAlpha = 0.9; ctx.fill();
      ctx.restore();
      ctx.save();
      ctx.beginPath(); ctx.arc(tipX, tipY, 3, 0, Math.PI * 2);
      ctx.fillStyle = c1; ctx.globalAlpha = 1; ctx.fill();
      ctx.restore();
    }

    function runGateVessel() {
      var cv = document.getElementById('vessel-canvas');
      if (!cv) return;
      if (_vesselRafId) { cancelAnimationFrame(_vesselRafId); _vesselRafId = null; }

      var gender = safeLower(state.member && (state.member.gender || state.member.sl_gender)) || 'male';
      var pathCurrent = safeLower(state.member && state.member.path_current) || '';
      var colors = getAlignmentColors(pathCurrent);
      var c1 = colors.fillA; var c2 = colors.fillB;
      var start = -Math.PI / 2;
      var W = cv.width; var H = cv.height;
      var cx = W / 2; var cy = H / 2;
      var baseR = Math.min(W, H) * 0.38;
      var figImg = null;

      loadVesselFigure(gender, function(src) { figImg = src; });

      function draw() {
        try {
          _vesselT += 0.016;
          var t = _vesselT;
          var qiCurrent = safeNumber(state.user && state.user.qi_current || state.member && state.member.qi_current, 0);
          var qiMax = safeNumber(state.user && state.user.qi_maximum || state.member && state.member.qi_maximum, 1);
          var qiPct = qiMax > 0 ? Math.min(1, qiCurrent / qiMax) : 0;
          _vesselCurrentQiPct = qiPct;

          var ctx = cv.getContext('2d');
          ctx.clearRect(0, 0, W, H);

          ctx.save();
          ctx.beginPath(); ctx.arc(cx, cy, baseR + 40, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(200,169,106,0.03)'; ctx.fill();
          ctx.restore();

          var v2StatusNow = safeLower(getV2CultivationStatus());
          var figureGone     = (v2StatusNow === 'in_breakthrough');
          var figureAscended = (v2StatusNow === 'idle' && !coalesce(state.member && state.member.v2_breakthrough_gate_open, false));
          var figureDamaged  = (v2StatusNow === 'awaiting_repair');

          var auraC1 = figureAscended ? 'rgba(255,230,120,0.9)' : figureDamaged ? 'rgba(200,80,80,0.7)' : c1;
          var auraC2 = figureAscended ? 'rgba(255,200,60,0.5)'  : figureDamaged ? 'rgba(160,40,40,0.4)'  : c2;
          var auraPct = figureGone ? qiPct * 0.4 : qiPct;
          drawVesselQiAura(ctx, cx, cy, baseR, auraPct, auraC1, auraC2, t, start);

          if (figImg && !figureGone) {
            try {
              var figH = baseR * (figureAscended ? 1.9 : figureDamaged ? 1.4 : 1.6);
              var figW = figH;
              var floatOffset = figureAscended ? Math.sin(t * 0.6) * 8 : Math.sin(t * 0.8) * 4;
              var figX = cx - figW * 0.5;
              var figY = cy - figH * (figureAscended ? 0.58 : 0.52) + floatOffset;
              if (figureDamaged) {
                figX = cx - figW * 0.5 - 10;
                figY = cy - figH * 0.45 + 10;
              }
              var rawC1 = figureAscended ? 'rgba(255,230,120,0.9)' : figureDamaged ? 'rgba(200,80,80,0.9)' : c1;
              var tr = parseInt(rawC1.replace('rgba(','').split(',')[0],10)||200;
              var tg = parseInt(rawC1.replace('rgba(','').split(',')[1],10)||169;
              var tb = parseInt(rawC1.replace('rgba(','').split(',')[2],10)||106;
              var off2 = document.createElement('canvas');
              off2.width = figImg.width; off2.height = figImg.height;
              var ctx2 = off2.getContext('2d');
              ctx2.drawImage(figImg, 0, 0);
              var id2 = ctx2.getImageData(0, 0, off2.width, off2.height);
              var d2 = id2.data;
              for (var i = 0; i < d2.length; i += 4) {
                if (d2[i+3] > 10) { d2[i] = tr; d2[i+1] = tg; d2[i+2] = tb; }
              }
              ctx2.putImageData(id2, 0, 0);
              ctx.save();
              if (figureDamaged) {
                ctx.translate(figX + figW * 0.5, figY + figH * 0.9);
                ctx.rotate(-0.25);
                ctx.globalAlpha = 0.7;
                ctx.drawImage(off2, -figW * 0.5, -figH * 0.9, figW, figH);
              } else {
                ctx.globalAlpha = figureAscended ? 1 : 0.92;
                ctx.drawImage(off2, figX, figY, figW, figH);
              }
              ctx.restore();
            } catch(fe) {}
          }

          var qiPctDisplay = Math.round(qiPct * 100);
          var qiLabel = document.getElementById('vessel-qi-label');
          var qiBarFill = document.getElementById('vessel-qi-bar-fill');
          if (qiLabel) qiLabel.textContent = qiPctDisplay + '%';
          if (qiBarFill) { qiBarFill.style.width = qiPctDisplay + '%'; qiBarFill.style.background = c1.replace('0.7)', '1)'); }

          if (figureGone) {
            var vTitleEl = document.getElementById('vessel-side-title');
            var vKickerEl = document.getElementById('vessel-side-kicker');
            if (vTitleEl) vTitleEl.textContent = 'In the Chamber';
            if (vKickerEl) vKickerEl.style.color = '#e8a84088';
          } else if (figureAscended) {
            var vTitleEl2 = document.getElementById('vessel-side-title');
            var vKickerEl2 = document.getElementById('vessel-side-kicker');
            if (vTitleEl2) vTitleEl2.textContent = 'Ascended';
            if (vKickerEl2) vKickerEl2.style.color = '#ffe87088';
          } else if (figureDamaged) {
            var vTitleEl3 = document.getElementById('vessel-side-title');
            var vKickerEl3 = document.getElementById('vessel-side-kicker');
            if (vTitleEl3) vTitleEl3.textContent = 'Cast Back';
            if (vKickerEl3) vKickerEl3.style.color = '#cc444488';
          }

        } catch(e) {}
        _vesselRafId = requestAnimationFrame(draw);
      }
      draw();
    }

    function stopGateVessel() {
      if (_vesselRafId) { cancelAnimationFrame(_vesselRafId); _vesselRafId = null; }
    }

    var _gateFigureCache = null;
    var _gateFigureLoading = false;
    var _gateFigureCallbacks = [];

    function loadGateFigure(gender, callback) {
      if (_gateFigureCache) { callback(_gateFigureCache); return; }
      _gateFigureCallbacks.push(callback);
      if (_gateFigureLoading) return;
      _gateFigureLoading = true;
      var url = (gender === 'female') ? '/female-figure.svg' : '/figure.svg';
      var img = new Image();
      img.onload = function() {
        try {
          var off = document.createElement('canvas');
          off.width = 1024; off.height = 1024;
          var ctx = off.getContext('2d');
          ctx.drawImage(img, 0, 0);
          var id = ctx.getImageData(0, 0, 1024, 1024);
          var d = id.data;
          for (var i = 0; i < d.length; i += 4) {
            if (d[i+3] > 10 && d[i] < 80 && d[i+1] < 80 && d[i+2] < 80) {
              d[i] = 200; d[i+1] = 169; d[i+2] = 106;
            } else { d[i+3] = 0; }
          }
          ctx.putImageData(id, 0, 0);
          _gateFigureCache = off;
        } catch(e) { _gateFigureCache = null; }
        _gateFigureLoading = false;
        var cbs = _gateFigureCallbacks.slice(); _gateFigureCallbacks = [];
        for (var j = 0; j < cbs.length; j++) { cbs[j](_gateFigureCache); }
      };
      img.onerror = function() {
        _gateFigureCache = null; _gateFigureLoading = false;
        var cbs = _gateFigureCallbacks.slice(); _gateFigureCallbacks = [];
        for (var j = 0; j < cbs.length; j++) { cbs[j](null); }
      };
      img.crossOrigin = 'anonymous';
      img.src = url;
    }

    function drawGateFigure(canvas, color, size, srcCanvas) {
      if (!canvas) return;
      canvas.width = size; canvas.height = size;
      var ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, size, size);
      if (srcCanvas) {
        try {
          var off2 = document.createElement('canvas');
          off2.width = srcCanvas.width; off2.height = srcCanvas.height;
          var ctx2 = off2.getContext('2d');
          ctx2.drawImage(srcCanvas, 0, 0);
          if (color !== '#c8a96a' && color !== '#c86890') {
            var id2 = ctx2.getImageData(0, 0, off2.width, off2.height);
            var d2 = id2.data;
            var tr = parseInt(color.slice(1,3),16)||200;
            var tg = parseInt(color.slice(3,5),16)||169;
            var tb = parseInt(color.slice(5,7),16)||106;
            for (var i = 0; i < d2.length; i += 4) {
              if (d2[i+3] > 10) { d2[i]=tr; d2[i+1]=tg; d2[i+2]=tb; }
            }
            ctx2.putImageData(id2, 0, 0);
          }
          ctx.drawImage(off2, 0, 0, size, size);
          return;
        } catch(e) {}
      }
      ctx.fillStyle = color;
      ctx.beginPath(); ctx.arc(size*0.5, size*0.5, size*0.35, 0, Math.PI*2); ctx.fill();
    }

    function resolveNextStageName(store) {
      try {
        var SECTION_KEYS = ['base','early','middle','late'];
        var vol = safeNumber(store && store.volume_number, 0);
        var focus = getFocusRecord();
        var sec = safeLower(focus && focus.section_key || '');
        var idx = SECTION_KEYS.indexOf(sec);
        if (idx === -1) return 'Next Stage';
        if (idx < SECTION_KEYS.length - 1) {
          var nextSec = SECTION_KEYS[idx + 1];
          return realmFromVolume(vol) + ' · ' + (nextSec.charAt(0).toUpperCase() + nextSec.slice(1));
        }
        return realmFromVolume(vol + 1) + ' · Base';
      } catch(e) { return 'Next Stage'; }
    }

    function renderBreakthroughFooter() {
      try {
        var store = getStore();
        var focus = getFocusRecord();
        var volumeNumber = safeNumber(store && store.volume_number, 0);
        var v2Status = safeLower(getV2CultivationStatus());
        var btControlsFlow = breakthroughControlsFlow();
        var showEntry = shouldShowBreakthroughEntry();
        var btState = btControlsFlow ? safeLower(getBreakthroughDisplayState()) : '';
        var gender = safeLower(state.member && (state.member.gender || state.member.sl_gender)) || 'male';

        var gateState = 'sealed';
        if (v2Status === 'awaiting_repair' || (focus && safeLower(focus.ui_state) === 'damaged')) {
          gateState = 'damaged';
        } else if (v2Status === 'in_breakthrough' || btState.includes('active') || btState.includes('countdown') || btState.includes('timer')) {
          gateState = 'active';
        } else if (showEntry || v2Status === 'breakthrough_ready') {
          gateState = 'open';
        } else if (v2Status === 'idle' && store && store.section_completed) {
          gateState = 'complete';
        } else if (v2Status === 'cultivating' || v2Status === 'paused') {
          gateState = 'cultivating';
        } else if (store && store.section_row_exists) {
          gateState = 'cultivating';
        }

        var progressPct = 0;
        if (focus) {
          var acc = safeNumber(focus.accumulated_seconds, 0);
          var req = safeNumber(focus.required_seconds, 0);
          progressPct = req > 0 ? Math.min(100, Math.round((acc / req) * 100)) : 0;
        }
        var fromLabel = volumeNumber > 0 ? realmFromVolume(volumeNumber) : '--';

        var wrap      = document.getElementById('gate-wrap');
        var kicker    = document.getElementById('gate-kicker');
        var titleEl   = document.getElementById('gate-title');
        var descEl    = document.getElementById('gate-desc');
        var scene     = document.getElementById('gate-scene');
        var archTop   = document.getElementById('gate-arch-top');
        var pillarL   = document.getElementById('gate-pillar-l');
        var pillarR   = document.getElementById('gate-pillar-r');
        var doorL     = document.getElementById('gate-door-l');
        var doorR     = document.getElementById('gate-door-r');
        var doorPanL  = document.getElementById('gate-door-panel-l');
        var doorPanR  = document.getElementById('gate-door-panel-r');
        var doorInL   = document.getElementById('gate-door-inner-l');
        var doorInR   = document.getElementById('gate-door-inner-r');
        var beam      = document.getElementById('gate-beam');
        var seam      = document.getElementById('gate-seam');
        var floor     = document.getElementById('gate-floor');
        var runeL     = document.getElementById('gate-rune-l');
        var runeM     = document.getElementById('gate-rune-m');
        var runeR     = document.getElementById('gate-rune-r');
        var bgLayer   = document.getElementById('gate-bg');
        var qiLayer   = document.getElementById('gate-qi-layer');
        var spLayer   = document.getElementById('gate-spark-layer');
        var progWrap  = document.getElementById('gate-progress-wrap');
        var progFill  = document.getElementById('gate-progress-fill');
        var actionBtn    = document.getElementById('gate-action-btn');
        var actionBtnOff = document.getElementById('gate-action-btn-off');
        var subNote   = document.getElementById('gate-sub-note');
        var chipsEl   = document.getElementById('gate-chips');
        var figCanvas = document.getElementById('gate-figure');
        var flash     = document.getElementById('gate-flash');
        if (!wrap) return;

        var C = {
          sealed:      {bg:'#080808',kc:'#555',tc:'rgba(255,255,255,0.3)',pBg:'#111',pBorder:'#222',aBg:'#111',aBorder:'#222',dBg:'#0e0e0e',dBorder:'#2a2a2a',dPanel:'#1f1f1f',dInner:'#181818',fBg:'#0d0d0d',fBorder:'#1a1a1a',seam:'#1a1a1a',seamAnim:false,dTL:'',dTR:'',beam:false,runes:false,figCol:'#444',figOp:0.2,figX:-145,figSz:85,figAnim:'none',starCol:'#333',stars:10,qi:false,sparks:false,prog:false},
          cultivating: {bg:'#060c12',kc:'#6aaccc',tc:null,pBg:'#0d1a24',pBorder:'#3a608055',aBg:'#0d1a24',aBorder:'#3a608066',dBg:'#0d1a24',dBorder:'#3a608066',dPanel:'#3a608044',dInner:'#3a608033',fBg:'#080f16',fBorder:'#3a608033',seam:'#3a608055',seamAnim:false,dTL:'',dTR:'',beam:false,runes:true,runeCol:'#3a608088',figCol:'#6aaccc',figOp:0.75,figX:-130,figSz:100,figAnim:'meditate',starCol:'#3a6080',stars:22,qi:true,sparks:false,prog:true,progCol:'#6aaccc'},
          complete:    {bg:'#0a0800',kc:'#c8a96a88',tc:null,pBg:'#1a1400',pBorder:'#c8a96a44',aBg:'#1a1400',aBorder:'#c8a96a44',dBg:'#1a1400',dBorder:'#c8a96a55',dPanel:'#c8a96a33',dInner:'#c8a96a22',fBg:'#1a1400',fBorder:'#c8a96a22',seam:'#c8a96a44',seamAnim:true,dTL:'',dTR:'',beam:false,runes:true,runeCol:'#c8a96a66',figCol:'#c8a96a',figOp:0.9,figX:-112,figSz:104,figAnim:'lean',starCol:'#c8a96a',stars:28,qi:false,sparks:false,prog:false},
          open:        {bg:'#0a0800',kc:'#c8a96a',tc:null,pBg:'#1e1600',pBorder:'#c8a96a66',aBg:'#1e1600',aBorder:'#c8a96a66',dBg:'#1e1600',dBorder:'#c8a96a66',dPanel:'#c8a96a44',dInner:'#c8a96a33',fBg:'#1a1400',fBorder:'#c8a96a33',seam:null,seamAnim:false,dTL:'perspective(300px) rotateY(-72deg)',dTR:'perspective(300px) rotateY(72deg)',beam:true,beamCol:'#c8a96a2a',beamSpd:'2.5s',runes:true,runeCol:'#c8a96a',figCol:'#c8a96a',figOp:1,figX:-130,figSz:110,figAnim:'meditate',starCol:'#c8a96a',stars:35,qi:false,sparks:true,prog:false},
          active:      {bg:'#0a0700',kc:'#e8a840',tc:null,pBg:'#1a1000',pBorder:'#e8a84066',aBg:'#1a1000',aBorder:'#e8a84066',dBg:'#1a1000',dBorder:'#e8a84066',dPanel:'#e8a84044',dInner:'#e8a84033',fBg:'#140c00',fBorder:'#e8a84033',seam:null,seamAnim:false,dTL:'perspective(300px) rotateY(-88deg)',dTR:'perspective(300px) rotateY(88deg)',beam:true,beamCol:'#e8a84022',beamSpd:'1.2s',runes:true,runeCol:'#e8a840',figCol:'#e8a840',figOp:0.45,figX:5,figSz:65,figAnim:'none',starCol:'#e8a840',stars:18,qi:false,sparks:true,prog:false},
          damaged:     {bg:'#080303',kc:'#cc4444',tc:null,pBg:'#150808',pBorder:'#7a202055',aBg:'#150808',aBorder:'#7a202066',dBg:'#150808',dBorder:'#aa303066',dPanel:'#7a202044',dInner:'#7a202033',fBg:'#100505',fBorder:'#7a202044',seam:'#cc444433',seamAnim:true,dTL:'perspective(300px) rotateY(-28deg) rotateZ(-4deg)',dTR:'perspective(300px) rotateY(22deg) rotateZ(3deg)',beam:false,runes:false,figCol:'#cc4444',figOp:0.85,figX:-168,figSz:95,figAnim:'knockback',starCol:'#7a2020',stars:12,qi:false,sparks:false,prog:false}
        };
        var c = C[gateState] || C.sealed;

        wrap.className = 'gate-wrap state-' + gateState;
        scene.style.background = c.bg;
        scene.className = 'gate-scene' + (gateState === 'open' ? ' is-clickable' : '');

        if (archTop)  { archTop.style.background = c.aBg;  archTop.style.border  = '1px solid ' + c.aBorder; }
        if (pillarL)  { pillarL.style.background = c.pBg;  pillarL.style.border  = '1px solid ' + c.pBorder; }
        if (pillarR)  { pillarR.style.background = c.pBg;  pillarR.style.border  = '1px solid ' + c.pBorder; }
        if (floor)    { floor.style.background   = c.fBg;  floor.style.borderTop = '1px solid ' + c.fBorder; }

        function applyDoor(el, pan, inn, tr) {
          if (!el) return;
          el.style.background = c.dBg; el.style.border = '1px solid ' + c.dBorder; el.style.transform = tr;
          if (pan) pan.style.border = '0.5px solid ' + c.dPanel;
          if (inn) inn.style.border = '0.5px solid ' + c.dInner;
        }
        applyDoor(doorL, doorPanL, doorInL, c.dTL);
        applyDoor(doorR, doorPanR, doorInR, c.dTR);

        if (seam) {
          if (c.seam) {
            seam.style.display = 'block'; seam.style.background = c.seam;
            seam.style.width = gateState === 'damaged' ? '3px' : '2px';
            seam.style.animation = c.seamAnim ? 'gateCrack 1.5s ease-in-out infinite' : 'none';
          } else { seam.style.display = 'none'; }
        }

        if (beam) {
          if (c.beam) {
            beam.style.display = 'block';
            beam.style.background = 'radial-gradient(ellipse at 50% 30%,' + c.beamCol + ' 0%,transparent 70%)';
            beam.style.animation = 'gateBeamPulse ' + c.beamSpd + ' ease-in-out infinite';
          } else { beam.style.display = 'none'; }
        }

        var runeCol = c.runes ? (c.runeCol || '#c8a96a') : 'transparent';
        if (runeL) { runeL.style.color = runeCol; runeL.style.animation = c.runes ? 'gateRuneGlow 2s infinite 0s' : 'none'; }
        if (runeM) { runeM.style.color = runeCol; runeM.style.animation = c.runes ? 'gateRuneGlow 2s infinite 0.7s' : 'none'; }
        if (runeR) { runeR.style.color = runeCol; runeR.style.animation = c.runes ? 'gateRuneGlow 2s infinite 1.4s' : 'none'; }
        if (kicker) kicker.style.color = c.kc;

        var titles = {sealed:'Gate Sealed',cultivating:'Comprehension in Progress',complete:"Awaiting Heaven's Judgment",open:'The Heavens Have Opened',active:'Breakthrough Underway',damaged:'The Gate Struck Back'};
        var descs  = {sealed:'This section has not yet been opened.',cultivating:'The cultivator meditates before the sealed gate. Keep cultivating to open the threshold.',complete:'Comprehension is complete. The heavens are judging your readiness.',open:'Your comprehension is complete. The gate stands open — enter and face your tribulation.',active:'The cultivator has passed through. Return to the chamber to face your verdict.',damaged:'The tribulation struck and fractured the record. Repair the damage to open the gate again.'};
        if (titleEl) { titleEl.textContent = titles[gateState] || 'Gate Sealed'; if (c.tc) titleEl.style.color = c.tc; else titleEl.style.color = ''; }
        if (descEl)  descEl.textContent = descs[gateState] || '';

        if (bgLayer) {
          bgLayer.innerHTML = '';
          for (var si = 0; si < c.stars; si++) {
            var st = document.createElement('div'); st.className = 'gate-star';
            st.style.cssText = 'left:'+Math.random()*100+'%;top:'+Math.random()*100+'%;background:'+c.starCol+';--td:'+(1.5+Math.random()*3)+'s;--ts:'+(Math.random()*3)+'s;';
            bgLayer.appendChild(st);
          }
        }
        if (qiLayer) {
          qiLayer.innerHTML = '';
          if (c.qi) {
            for (var qi = 0; qi < 14; qi++) {
              var qd = document.createElement('div'); qd.className = 'gate-qi';
              qd.style.cssText = 'left:'+(25+Math.random()*25)+'%;bottom:'+(28+Math.random()*25)+'px;background:'+c.starCol+'88;--qd:'+(1.2+Math.random()*2)+'s;--qs:'+(Math.random()*3)+'s;';
              qiLayer.appendChild(qd);
            }
          }
        }
        if (spLayer) {
          spLayer.innerHTML = '';
          if (c.sparks) {
            for (var sp = 0; sp < 18; sp++) {
              var spk = document.createElement('div'); spk.className = 'gate-spark';
              var ang = Math.random()*Math.PI*2, dist = 20+Math.random()*55;
              spk.style.cssText = 'left:calc(50% + '+(Math.random()*30-15)+'px);top:'+(35+Math.random()*35)+'%;background:'+c.starCol+';--sd:'+(0.9+Math.random()*1.3)+'s;--ss:'+(Math.random()*2.5)+'s;--sx:'+(Math.cos(ang)*dist)+'px;--sy:'+(Math.sin(ang)*dist-18)+'px;';
              spLayer.appendChild(spk);
            }
          }
        }

        if (progWrap) {
          progWrap.style.display = c.prog ? 'block' : 'none';
          if (c.prog && progFill) { progFill.style.width = progressPct + '%'; progFill.style.background = c.progCol || '#6aaccc'; }
        }

        if (figCanvas) {
          figCanvas.style.animation = 'none';
          figCanvas.style.transform = '';
          figCanvas.style.transformOrigin = '';
          figCanvas.style.opacity = String(c.figOp);
          figCanvas.style.left = 'calc(50% + ' + c.figX + 'px)';
          figCanvas.style.transition = 'left 0.4s ease, opacity 0.4s ease';
          if (c.figAnim === 'meditate')  figCanvas.style.animation = 'gateMeditate 3s ease-in-out infinite';
          if (c.figAnim === 'knockback') { figCanvas.style.animation = 'gateKnockback 2s ease-in-out infinite'; figCanvas.style.transformOrigin = 'bottom center'; }
          if (c.figAnim === 'lean')      { figCanvas.style.transform = 'rotate(-8deg)'; figCanvas.style.transformOrigin = 'bottom center'; }
          window._gateCurrentFigColor = c.figCol;
          window._gateCurrentFigSize  = c.figSz;
          loadGateFigure(gender, function(src) { drawGateFigure(figCanvas, c.figCol, c.figSz, src); });
        }

        var chips = [];
        if (gateState === 'sealed') {
          chips = [{label:'Section',val:'Not Opened',lc:'#444',vc:'#555',bg:'#111',bc:'#222'}];
        } else if (gateState === 'cultivating') {
          var remSecs = focus ? safeNumber(focus.remaining_display_seconds || focus.remaining_seconds, 0) : 0;
          chips = [
            {label:'Progress', val:progressPct+'%',                            lc:'#3a608099',vc:'#6aaccc',bg:'#0d1a2a',bc:'#3a608055'},
            {label:'Remaining',val:remSecs > 0 ? formatDuration(remSecs) : '--', lc:'#3a608099',vc:'#6aaccc',bg:'#0d1a2a',bc:'#3a608055'},
            {label:'Gate',     val:'Stirring',                                 lc:'#3a608099',vc:'#6aaccc',bg:'#0d1a2a',bc:'#3a608055'}
          ];
        } else if (gateState === 'complete') {
          chips = [{label:'Gate',val:'Judging',lc:'#c8a96a66',vc:'#c8a96a88',bg:'#1a1400',bc:'#c8a96a33'}];
        } else if (gateState === 'open') {
          chips = [
            {label:'From',       val:fromLabel,    lc:'#c8a96a88',vc:'#c8a96a',bg:'#1a1400',bc:'#c8a96a44'},
            {label:'To',         val:resolveNextStageName(store), lc:'#c8a96a88',vc:'#c8a96a',bg:'#1a1400',bc:'#c8a96a44'},
            {label:'Tribulation',val:'Tempering',  lc:'#c8a96a88',vc:'#c8a96a',bg:'#1a1400',bc:'#c8a96a44'}
          ];
        } else if (gateState === 'active') {
          chips = [
            {label:'Chamber',val:'Active',         lc:'#e8a84088',vc:'#e8a840',bg:'#140c00',bc:'#e8a84044'},
            {label:'Status', val:'Battle Underway',lc:'#e8a84088',vc:'#e8a840',bg:'#140c00',bc:'#e8a84044'}
          ];
        } else if (gateState === 'damaged') {
          var repairCp  = focus ? safeNumber(focus.repair_cp_cost, 0) : 0;
          var resumePct = focus ? safeNumber(focus.repair_resume_from_percent || focus.retained_comprehension_percent, 0) : 0;
          chips = [
            {label:'Repair Cost', val:repairCp+' CP', lc:'#7a202088',vc:'#cc4444',bg:'#150808',bc:'#7a202055'},
            {label:'Resume From', val:resumePct+'%',  lc:'#7a202088',vc:'#cc4444',bg:'#150808',bc:'#7a202055'}
          ];
        }
        if (chipsEl) {
          chipsEl.innerHTML = chips.map(function(ch) {
            return '<div class="gate-chip" style="background:'+ch.bg+';border:0.5px solid '+ch.bc+';">'
              +'<span style="color:'+ch.lc+';">'+ch.label+'</span>'
              +'<strong style="color:'+ch.vc+';">'+ch.val+'</strong></div>';
          }).join('');
        }

        if (actionBtn)    actionBtn.style.display    = 'none';
        if (actionBtnOff) actionBtnOff.style.display = 'none';
        if (subNote)      subNote.textContent = '';

        if (gateState === 'sealed') {
          actionBtnOff.style.display = 'block'; actionBtnOff.style.background = '#111'; actionBtnOff.style.border = '0.5px solid #222'; actionBtnOff.style.color = '#444'; actionBtnOff.textContent = 'Gate Sealed';
        } else if (gateState === 'cultivating') {
          actionBtnOff.style.display = 'block'; actionBtnOff.style.background = '#0d1a2a'; actionBtnOff.style.border = '0.5px solid #3a608055'; actionBtnOff.style.color = '#3a6080'; actionBtnOff.textContent = 'Gate Closed — Keep Cultivating';
          subNote.textContent = 'The threshold will manifest when comprehension is complete.'; subNote.style.color = '#3a608077';
        } else if (gateState === 'complete') {
          actionBtnOff.style.display = 'block'; actionBtnOff.style.background = '#1a1400'; actionBtnOff.style.border = '0.5px solid #c8a96a44'; actionBtnOff.style.color = '#c8a96a66'; actionBtnOff.textContent = "Awaiting Heaven's Judgment";
        } else if (gateState === 'open') {
          var focusSession = getFocusRecord();
          var isMeditating = focusSession && focusSession.session_started_at != null;
          if (isMeditating) {
            actionBtn.style.display = 'block';
            actionBtn.style.background = '#c8a96a';
            actionBtn.style.color = '#1a1200';
            actionBtn.textContent = 'Enter the Breakthrough Chamber';
            actionBtn.disabled = false;
            actionBtn.onclick = function() { runGateCinematic(); };
            subNote.textContent = 'Face the heavenly tribulation and ascend — or be cast back.';
            subNote.style.color = '#c8a96a77';
          } else {
            actionBtnOff.style.display = 'block';
            actionBtnOff.style.background = '#1a1400';
            actionBtnOff.style.border = '0.5px solid #c8a96a44';
            actionBtnOff.style.color = '#c8a96a66';
            actionBtnOff.textContent = 'Begin Meditation to Channel Qi into the Gate';
            subNote.textContent = 'The gate is open but your qi is still. Meditate to channel your energy into the threshold.';
            subNote.style.color = '#c8a96a55';
          }
        } else if (gateState === 'active') {
          actionBtn.style.display = 'block'; actionBtn.style.background = '#e8a840'; actionBtn.style.color = '#1a0f00'; actionBtn.textContent = 'Return to Breakthrough Chamber';
          actionBtn.onclick = function() { window.location.href = getBreakthroughRoute(); };
        } else if (gateState === 'damaged') {
          actionBtn.style.display = 'block'; actionBtn.style.background = '#7a2020'; actionBtn.style.color = '#ffe0e0'; actionBtn.textContent = 'Repair the Record'; actionBtn.onclick = null;
        }
      } catch(e) {
        console.error('renderBreakthroughFooter error:', e);
      }
    }

    function runGateCinematic() {
      try {
        var doorL  = document.getElementById('gate-door-l');
        var doorR  = document.getElementById('gate-door-r');
        var flash  = document.getElementById('gate-flash');
        var btn    = document.getElementById('gate-action-btn');
        var note   = document.getElementById('gate-sub-note');
        var vessel = document.getElementById('vessel-canvas');
        var dualPanel = document.querySelector('.vessel-gate-panel');
        if (!doorL || !vessel || !dualPanel) { window.location.href = getBreakthroughRoute(); return; }
        if (btn) btn.disabled = true;

        var panelRect  = dualPanel.getBoundingClientRect();
        var vesselRect = vessel.getBoundingClientRect();
        var doorLEl    = document.getElementById('gate-door-l');
        var gateScene  = document.getElementById('gate-scene');
        var gateRect   = gateScene ? gateScene.getBoundingClientRect() : null;

        var startX = vesselRect.left - panelRect.left + vesselRect.width * 0.5;
        var startY = vesselRect.top  - panelRect.top  + vesselRect.height * 0.5;
        var endX   = gateRect ? (gateRect.left - panelRect.left + gateRect.width * 0.5) : panelRect.width * 0.75;
        var endY   = gateRect ? (gateRect.top  - panelRect.top  + gateRect.height * 0.5) : startY;

        var clone = document.createElement('canvas');
        clone.width  = vessel.width;
        clone.height = vessel.height;
        var cloneCtx = clone.getContext('2d');
        cloneCtx.drawImage(vessel, 0, 0);

        var sz = vessel.width;
        clone.style.cssText = 'position:absolute;z-index:50;pointer-events:none;'
          + 'width:' + sz + 'px;height:' + sz + 'px;'
          + 'left:' + (startX - sz * 0.5) + 'px;'
          + 'top:'  + (startY - sz * 0.5) + 'px;'
          + 'transition:none;';

        dualPanel.style.position = 'relative';
        dualPanel.style.overflow = 'visible';
        dualPanel.appendChild(clone);

        vessel.style.opacity = '0';

        doorL.style.transform = 'perspective(300px) rotateY(-88deg)';
        doorR.style.transform = 'perspective(300px) rotateY(88deg)';
        if (note) note.textContent = 'The gate opens...';

        setTimeout(function() {
          if (note) note.textContent = 'Entering the threshold...';
          clone.style.transition = 'left 1.6s cubic-bezier(0.4,0,0.3,1), top 1.6s cubic-bezier(0.4,0,0.3,1), width 1.6s ease, height 1.6s ease, opacity 0.5s ease 1.1s';
          var targetSz = Math.round(sz * 0.25);
          clone.style.width   = targetSz + 'px';
          clone.style.height  = targetSz + 'px';
          clone.style.left    = (endX - targetSz * 0.5) + 'px';
          clone.style.top     = (endY - targetSz * 0.5) + 'px';
          clone.style.opacity = '0.3';
        }, 300);

        setTimeout(function() {
          if (note) note.textContent = 'Passing through...';
          clone.style.opacity = '0';
        }, 1600);

        setTimeout(function() {
          if (note) note.textContent = 'Ascending...';
          if (flash) flash.style.opacity = '0.65';
          stopGateVessel();
          var avatarKey = (state && state.member && state.member.sl_avatar_key) || (state && state.user && state.user.sl_avatar_key) || '';
          if (avatarKey) {
            fetch('/.netlify/functions/enter-breakthrough', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ sl_avatar_key: avatarKey })
            }).catch(function() {});
          }
        }, 2000);

        setTimeout(function() {
          if (flash) flash.style.opacity = '0';
        }, 2400);

        setTimeout(function() {
          if (note) note.textContent = 'Entering the Breakthrough Chamber...';
          window.location.href = getBreakthroughRoute();
        }, 2800);

      } catch(e) {
        window.location.href = getBreakthroughRoute();
      }
    }

    function renderPrimaryAction() {
      try {
        var action = getPrimaryActionPayload();
        var button = document.getElementById("primary-action-button");
        var note = document.getElementById("action-note");
        var secondary = document.getElementById("secondary-action-button");
        var actionWell = document.querySelector(".action-well");
        var v2Status = safeLower(getV2CultivationStatus());
        var showEntry = shouldShowBreakthroughEntry();

        if (!action || safeLower(action.type) === "disabled") {
          if (button) { button.textContent = safeText(action && action.label, "No Action Available"); button.setAttribute("aria-disabled", "true"); }
        } else {
          if (button) { button.textContent = state.actionPending ? "Processing..." : safeText(action.label, "Continue"); button.setAttribute("aria-disabled", state.actionPending ? "true" : "false"); }
        }
        if (note) {
          var noteText = safeText(action && action.note, "Checking the next valid altar action...");
          note.textContent = noteText + (safeText(action && action.cost_text) ? " Cost: " + safeText(action.cost_text) + "." : "");
        }
        if (secondary) { secondary.href = "/cultivation.html"; secondary.textContent = "Meditation Page"; }
        if (actionWell) {
          var hideActionWell = showEntry || v2Status === 'breakthrough_ready' || v2Status === 'in_breakthrough';
          actionWell.style.display = hideActionWell ? 'none' : '';
        }
      } catch(e) {
        console.error('renderPrimaryAction error:', e);
      }
    }

    function attachActionHandlers() {
      const button = document.getElementById("primary-action-button");
      if (!button) return;

      button.onclick = async function (event) {
        event.preventDefault();

        if (state.actionPending) return;
        if (!state.member || !state.actionState) return;

        const action = state.actionState;
        const type = safeLower(action.type);

        if (type === "disabled") return;

        if (type === "route") {
          window.location.href = safeText(action.href || action.endpoint, getBreakthroughRoute());
          return;
        }

        await handlePrimaryAction(action);
      };
    }

    async function handlePrimaryAction(action) {
      state.actionPending = true;
      setMessage("");
      renderPrimaryAction();

      try {
        const endpoint = safeText(action.endpoint);
        if (!endpoint) {
          throw new Error("No endpoint configured for this action.");
        }

        const method = safeUpper(action.method || "POST");
        const store = getStore();
        const volumeNumber =
          safeNumber(store?.volume_number, 0) ||
          safeNumber(state.requestedVolumeNumber, 0) ||
          null;

        const basePayload = {
          sl_avatar_key: safeText(state.user?.sl_avatar_key || state.member?.sl_avatar_key),
          sl_username: safeText(state.user?.sl_username || state.member?.sl_username),
          volume_number: volumeNumber,
          source_page: "cultivation-book"
        };

        const payload = Object.assign({}, basePayload, action.action_params || {});
        let response;
        let data;

        if (method === "GET") {
          const params = new URLSearchParams();
          Object.entries(payload).forEach(([key, value]) => {
            if (value !== null && value !== undefined && String(value).trim() !== "") {
              params.set(key, String(value));
            }
          });

          data = await fetchJson(endpoint + "?" + params.toString(), {
            method: "GET"
          });
        } else {
          const csrfToken = getCsrfToken();

          data = await fetchJson(endpoint, {
            method: method,
            headers: {
              "Content-Type": "application/json",
              ...(csrfToken ? { "X-AP-CSRF-Token": csrfToken } : {})
            },
            body: JSON.stringify(payload)
          });
        }

        if (!data.success) {
          throw new Error(safeText(data.message, "Action failed."));
        }

        if (safeText(data.redirect_url)) {
          window.location.href = safeText(data.redirect_url);
          return;
        }

        setMessage(safeText(data.message, "Action completed."));
        await loadBookState();

        if (breakthroughControlsFlow()) {
          const autoRoute = safeBoolean(getBreakthroughUi()?.auto_route_after_action, true);
          if (autoRoute) {
            window.location.href = getBreakthroughRoute();
            return;
          }
        }
      } catch (error) {
        if (String(error?.message || "") === "unauthorized") {
          return;
        }

        console.error("Action error:", error);
        setMessage(error.message || "Failed to process action.", "error");
        if (state.record) renderPage();
      } finally {
        state.actionPending = false;
        if (state.record) renderPage();
      }
    }

    function renderNotFound(title, text) {
      document.getElementById("main-shell").classList.add("is-hidden");
      document.getElementById("empty-root").innerHTML = `
        <section class="empty-state-panel">
          <h2>${safeText(title, "Record not available")}</h2>
          <p>${safeText(text, "Return to your library and open an available record.")}</p>
          <div class="empty-state-actions">
            <a href="/library.html" class="action-secondary">Back to Library</a>
            <a href="/store.html" class="action-primary">Go to Store</a>
          </div>
        </section>
      `;
    }

    function clearNotFound() {
      document.getElementById("main-shell").classList.remove("is-hidden");
      document.getElementById("empty-root").innerHTML = "";
    }

    function renderPage() {
      const record = getRecord();

      if (!record?.available) {
        renderNotFound(
          "Unable to open this cultivation record",
          safeText(record?.message, "Return to your library and try again.")
        );
        return;
      }

      clearNotFound();
      renderHero();
      renderPath();
      renderAltar();
      renderContext();
      renderBreakthroughFooter();
      renderPrimaryAction();
      attachActionHandlers();
    }

    async function loadViewerSession() {
      try {
        const data = await fetchJson(DASHBOARD_ENDPOINT, {
          method: "GET"
        });

        if (!data?.success || !data.member) {
          clearClientSessionArtifacts();
          redirectToLogin();
          return false;
        }

        state.member = data.member;
        return true;
      } catch (error) {
        if (String(error?.message || "") === "unauthorized") {
          return false;
        }

        console.error("Session load error:", error);
        clearClientSessionArtifacts();
        redirectToLogin();
        return false;
      }
    }

    async function fetchMemberState() {
      const params = new URLSearchParams();
      const member = state.member || {};

      if (member.sl_avatar_key) params.set("sl_avatar_key", member.sl_avatar_key);
      if (member.sl_username) params.set("sl_username", member.sl_username);
      params.set("source_page", "cultivation-book");

      return fetchJson(MEMBER_STATE_ENDPOINT + "?" + params.toString(), {
        method: "GET"
      });
    }

    async function fetchBookState() {
      const params = new URLSearchParams();
      const member = state.member || {};

      if (member.sl_avatar_key) params.set("sl_avatar_key", member.sl_avatar_key);
      if (member.sl_username) params.set("sl_username", member.sl_username);
      if (safeNumber(state.requestedVolumeNumber, 0) > 0) {
        params.set("volume_number", String(state.requestedVolumeNumber));
      }
      params.set("source_page", "cultivation-book");

      return fetchJson(BOOK_STATE_ENDPOINT + "?" + params.toString(), {
        method: "GET"
      });
    }

    async function loadBookState() {
      state.record = null;
      state.actionState = null;

      try {
        try {
          const memberData = await fetchMemberState();
          state.member = Object.assign({}, state.member || {}, memberData || {});
        } catch (memberError) {
          if (String(memberError?.message || "") !== "unauthorized") {
            console.error("Member state preload error:", memberError);
          } else {
            return;
          }
        }

        let data = await fetchBookState();
        let nextRecord = data.cultivation_record || null;
        let nextUser = data.user || null;

        if (nextUser) {
          state.member = Object.assign({}, state.member || {}, nextUser);
        }

        const serverSelectedVolume = safeNumber(nextRecord?.selected_volume_number, 0);
        const requestedVolume = safeNumber(state.requestedVolumeNumber, 0);

        if (serverSelectedVolume > 0 && serverSelectedVolume !== requestedVolume) {
          state.requestedVolumeNumber = serverSelectedVolume;
          syncVolumeQuery(serverSelectedVolume);

          data = await fetchBookState();
          nextRecord = data.cultivation_record || null;
          nextUser = data.user || null;

          if (nextUser) {
            state.member = Object.assign({}, state.member || {}, nextUser);
          }
        }

        state.record = nextRecord;
        state.user = nextUser || null;

        adoptServerSelectedVolume(state.record);
        syncCosmeticTimer();
        renderPage();

        if (Array.isArray(data.warnings) && data.warnings.length) {
          setMessage(data.warnings.join(" "), "info");
        } else {
          setMessage("");
        }
      } catch (error) {
        if (String(error?.message || "") === "unauthorized") {
          return;
        }

        console.error("Book state load error:", error);
        renderNotFound("Unable to load this opened record", error.message || "Return to your library and try again.");
        setMessage(error.message || "Failed to load cultivation book state.", "error");
      }
    }

    async function silentRefresh() {
      if (state.refreshInFlight || state.actionPending) return;

      state.refreshInFlight = true;

      try {
        let data = await fetchBookState();
        let nextRecord = data.cultivation_record || null;
        let nextUser = data.user || null;

        if (nextUser) {
          state.member = Object.assign({}, state.member || {}, nextUser);
        }

        const serverSelectedVolume = safeNumber(nextRecord?.selected_volume_number, 0);
        const requestedVolume = safeNumber(state.requestedVolumeNumber, 0);

        if (serverSelectedVolume > 0 && serverSelectedVolume !== requestedVolume) {
          state.requestedVolumeNumber = serverSelectedVolume;
          syncVolumeQuery(serverSelectedVolume);

          data = await fetchBookState();
          nextRecord = data.cultivation_record || null;
          nextUser = data.user || null;

          if (nextUser) {
            state.member = Object.assign({}, state.member || {}, nextUser);
          }
        }

        state.record = nextRecord;
        state.user = nextUser || null;

        adoptServerSelectedVolume(state.record);
        syncCosmeticTimer();
        renderPage();
      } catch (error) {
        if (String(error?.message || "") !== "unauthorized") {
          console.error("Silent refresh error:", error);
        }
      } finally {
        state.refreshInFlight = false;
      }
    }

    function startCosmeticTick() {
      if (state.cosmeticTickInterval) {
        clearInterval(state.cosmeticTickInterval);
      }

      state.cosmeticTickInterval = setInterval(function () {
        if (state.actionPending || !state.record) return;

        if (state.displayIsActive && state.displayRemainingSeconds > 0) {
          state.displayRemainingSeconds = Math.max(0, state.displayRemainingSeconds - 1);
          const remainingEl = document.getElementById("altar-remaining-value");
          if (remainingEl) {
            remainingEl.textContent = formatDuration(state.displayRemainingSeconds);
          }
        }
      }, 1000);
    }

    function startAutoRefresh() {
      if (state.refreshInterval) {
        clearInterval(state.refreshInterval);
      }

      state.refreshInterval = setInterval(function () {
        if (!state.member || state.actionPending || state.refreshInFlight) return;
        silentRefresh();
      }, 30000);
    }

    async function init() {
      state.requestedVolumeNumber = getVolumeFromQuery();

      startCosmeticTick();
      startAutoRefresh();

      const auth = await requireAuth();
      if (!auth) return;

      const sessionOk = await loadViewerSession();
      if (!sessionOk) return;

      await loadBookState();
    }

    window.addEventListener("DOMContentLoaded", function () {
      bindLogoutButton();
      init();
    });

    window.addEventListener("beforeunload", function () {
      if (state.cosmeticTickInterval) {
        clearInterval(state.cosmeticTickInterval);
      }

      if (state.refreshInterval) {
                clearInterval(state.refreshInterval);
      }
    });
  </script>
</body>
</html>